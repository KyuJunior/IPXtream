<Window x:Class="IPXtream.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:fl="clr-namespace:FlyleafLib.Controls.WPF;assembly=FlyleafLib"
        mc:Ignorable="d"
        Title="IPXtream"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F1A"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDeep"       Color="#0F0F1A"/>
        <SolidColorBrush x:Key="BgSidebar"    Color="#12122A"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1A1A2E"/>
        <SolidColorBrush x:Key="BgHover"      Color="#22224A"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#4F8EF7"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7C5CBF"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#888899"/>
        <SolidColorBrush x:Key="InputBg"      Color="#12122A"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#2E2E50"/>
        <SolidColorBrush x:Key="DividerColor" Color="#1E1E3A"/>
        <SolidColorBrush x:Key="ErrorRed"     Color="#FF5370"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#4EC994"/>

        <!-- ── Category list item ──────────────────────────────────────────── -->
        <Style x:Key="CategoryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stream card ────────────────────────────────────────────────── -->
        <Style x:Key="StreamItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="{TemplateBinding Margin}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Search TextBox ──────────────────────────────────────────────── -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Play button ────────────────────────────────────────────────── -->
        <Style x:Key="PlayBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Player control button ──────────────────────────────────────── -->
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Width"           Value="38"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="19" Background="#55FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#AAFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── Window load animation ──────────────────────────────────────────────── -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.35"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!--
        Root Grid has two layers:
          [0] Dashboard content (sidebar + categories + streams)
          [1] Player panel — hidden by default, slides over the content area (columns 1+2)
              when a stream is playing. Sidebar stays visible.
    -->
    <Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             LAYER 0 — DASHBOARD
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="DashboardGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="230">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="230"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════ SIDEBAR ══════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,24,20,20">
                        <Border Width="36" Height="36" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="📺" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="IPXtream" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Nav -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="live"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=LiveTV}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📡" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Live TV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="vod"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=VOD}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎬" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Movies" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="series"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=Series}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎞️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Series" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="whatsnew"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=WhatsNew}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔥" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="What's new?" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="{StaticResource DividerColor}" Margin="16,16"/>

                        <!-- Cache / Cancel toggle -->
                        <Button Style="{StaticResource NavBtn}" Command="{Binding CacheAllBackgroundCommand}"
                                Visibility="{Binding IsCachingAll, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="☁️" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Cache Entire Library" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavBtn}" Command="{Binding CancelCacheCommand}"
                                Visibility="{Binding IsCachingAll, Converter={StaticResource BoolToVisibilityConverter}}"
                                Foreground="#FF5370">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏹" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Cancel Caching" VerticalAlignment="Center"
                                           Foreground="#FF5370"/>
                            </StackPanel>
                        </Button>

                        <!-- Downloads toggle with active badge -->
                        <Button Style="{StaticResource NavBtn}" Command="{Binding ToggleDownloadsTrayCommand}"
                                Margin="0,4,0,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬇" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="Downloads" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Active download count badge -->
                                <Border Background="{StaticResource AccentBlue}" CornerRadius="8"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Padding="5,1" Margin="0,0,8,0"
                                        Visibility="{Binding HasActiveDownloads,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ActiveDownloadCount}"
                                               FontSize="10" Foreground="White"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Command="{Binding RefreshCommand}" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Refresh Current View" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Command="{Binding LogoutCommand}" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" FontSize="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Logout" VerticalAlignment="Center"
                                           Foreground="{StaticResource ErrorRed}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- User footer -->
                    <Border Grid.Row="2" Background="{StaticResource BgCard}"
                            CornerRadius="12" Margin="12,0,12,16" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayUsername}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ServerDisplay}"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" Margin="0,2,0,0"/>

                            <!-- Version + Update row -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Version label -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding AppVersion}"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="10" VerticalAlignment="Center"/>

                                <!-- Check for Updates button -->
                                <Button Grid.Column="1"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="4,1" ToolTip="Check for updates">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="IsEnabled" Value="True"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock FontSize="10" Foreground="{StaticResource AccentBlue}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Check"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                                                        <Setter Property="Text" Value="…"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <!-- Update status (shown after check) -->
                            <TextBlock Text="{Binding UpdateStatus}"
                                       FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding UpdateStatus}" Value=""/>
                                                </MultiDataTrigger.Conditions>
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding UpdateStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Clickable "open release page" — only shows when update is available -->
                            <Button Command="{Binding DownloadAndInstallUpdateCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="0,2" HorizontalAlignment="Left"
                                    ToolTip="Download and install update">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <!-- Show if update URL is present AND not currently downloading -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding UpdateUrl, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible"/>
                                                    <Condition Binding="{Binding IsDownloadingUpdate}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="→ Download now"
                                           FontSize="10"
                                           Foreground="{StaticResource AccentGreen}"
                                           TextDecorations="Underline"/>
                            </Button>

                            <!-- In-app Download Progress Panel -->
                            <StackPanel Margin="0,4,0,0" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding UpdateDownloadStatus}"
                                           FontSize="10" Foreground="{StaticResource AccentBlue}"
                                           Margin="0,0,0,4"/>
                                <ProgressBar Height="4" Minimum="0" Maximum="1"
                                             Value="{Binding UpdateDownloadProgress, Mode=OneWay}"
                                             Background="#1F1F3D" Foreground="{StaticResource AccentBlue}"
                                             BorderThickness="0"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- ══════════ CATEGORIES ════════════════════════════════════════ -->
            <Border x:Name="CategoriesPanel" Grid.Column="1" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource DividerColor}" BorderThickness="0,0,1,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16,16,16,12">
                        <StackPanel>
                            <TextBlock Text="CATEGORIES"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="Loading…"
                                       Foreground="{StaticResource AccentBlue}"
                                       FontSize="12" Margin="0,4,0,0"
                                       Visibility="{Binding IsLoadingCategories,
                                                    Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource CategoryItemStyle}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CategoryName}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Error + Retry -->
                    <Border Grid.Row="1" VerticalAlignment="Top"
                            Background="#441A0A" CornerRadius="8"
                            Padding="10,8" Margin="8,4"
                            Visibility="{Binding ErrorMessage,
                                         Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#FF7B6B" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <Button Command="{Binding SelectSectionCommand}" CommandParameter="live"
                                    Background="#4F8EF7" Foreground="White"
                                    BorderThickness="0" Padding="8,4"
                                    FontSize="11" FontWeight="Bold" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                &#x21BA; Retry
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════ STREAMS ═══════════════════════════════════════════ -->
            <Grid x:Name="StreamsPanel" Grid.Column="2" Background="{StaticResource BgDeep}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>  <!-- Seasons tabs -->
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>  <!-- downloads tray -->
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" Height="38"
                                 Foreground="White"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedCategory.CategoryName}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="16,0,0,0"
                                   Visibility="{Binding HasSelectedCategory,
                                                Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- Error banner -->
                <Border Grid.Row="0" VerticalAlignment="Bottom"
                        Background="#3DFF5370" CornerRadius="8"
                        Padding="12,6" Margin="16,0,16,4"
                        Visibility="{Binding ErrorMessage,
                                     Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorRed}" FontSize="12"/>
                </Border>

                <!-- Seasons Tabs -->
                <ListBox Grid.Row="1" ItemsSource="{Binding Seasons}" SelectedItem="{Binding SelectedSeason}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         Background="Transparent" BorderThickness="0,1,0,1" BorderBrush="#1C1C28" Padding="14,0"
                         Visibility="{Binding IsViewingSeriesInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="16,10"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border BorderThickness="0,0,0,3" BorderBrush="Transparent" x:Name="Bd" Background="{TemplateBinding Background}">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A1A2E"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Stream card grid -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Streams}"
                         SelectedItem="{Binding SelectedStream}"
                         ItemContainerStyle="{StaticResource StreamItemStyle}"
                         Background="Transparent" BorderThickness="0" Padding="10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="150" Height="220" CornerRadius="8" Background="{StaticResource BgSidebar}" ClipToBounds="True">
                                <Grid>
                                    <!-- Poster -->
                                    <Image Source="{Binding StreamIcon, Converter={StaticResource CachedImageConverter}}"
                                           Stretch="UniformToFill">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <Trigger Property="Source" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    
                                    <!-- Fallback empty state icon -->
                                    <TextBlock Text="📺" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StreamIcon}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StreamIcon}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Dark Gradient for Text -->
                                    <Border VerticalAlignment="Bottom" Height="80">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0"/>
                                                <GradientStop Color="#E60D0D1A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White" FontSize="12" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="36"
                                               Margin="10,0,10,12" VerticalAlignment="Bottom" HorizontalAlignment="Center" TextAlignment="Center"/>

                                    <!-- Hover Overlay with Buttons -->
                                    <Border x:Name="HoverOverlay" Background="#99000000" Opacity="0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- Play -->
                                            <Button Style="{StaticResource PlayBtn}" Width="44" Height="44" Padding="0" FontSize="18"
                                                    Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="PlayBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                                            <TextBlock Text="▶" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="PlayBd" Property="Background" Value="#4F8EF7"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            
                                            <!-- Download -->
                                            <Button Margin="12,0,0,0" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                                    Visibility="{Binding IsDownloadable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Command="{Binding DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Download to ~/Downloads/IPXtream/&#x0a;(Includes all embedded subtitles automatically)">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="DlBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                                            <TextBlock Text="⬇" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="DlBd" Property="Background" Value="#66FFFFFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Toggle Featured (Star Button) -->
                                            <Button Margin="12,0,0,0" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                                    Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Command="{Binding DataContext.ToggleFeaturedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Add / Remove from What's new?">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="StarBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                                            <TextBlock x:Name="StarTxt" Text="☆" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="StarBd" Property="Background" Value="#66FFFFFF"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsFeatured}" Value="True">
                                                                <Setter TargetName="StarTxt" Property="Text" Value="★"/>
                                                                <Setter TargetName="StarTxt" Property="Foreground" Value="#FFD700"/>
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Empty state -->
                <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasSelectedCategory,
                                         Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TextBlock Text="👈" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Select a category to browse"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Loading overlay -->
                <Border Grid.Row="1" Background="#88000000"
                        Visibility="{Binding IsLoadingStreams,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Loading streams…"
                               Foreground="{StaticResource AccentBlue}"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Status bar -->
                <Border Grid.Row="3" Background="{StaticResource BgCard}"
                        BorderBrush="{StaticResource DividerColor}" BorderThickness="0,1,0,0"
                        Padding="16,6">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextMuted}" FontSize="12"/>
                </Border>

                <!-- ── Downloads tray ─────────────────────────────────────── -->
                <Border Grid.Row="4" Background="#0D0D1E"
                        BorderBrush="{StaticResource AccentBlue}" BorderThickness="0,1,0,0"
                        Visibility="{Binding ShowDownloadsTray,
                                     Converter={StaticResource BoolToVisibilityConverter}}"
                        MaxHeight="240">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tray header -->
                        <Border Grid.Row="0" Padding="14,7" Background="#12122A">
                            <Grid>
                                <TextBlock Text="DOWNLOADS" Foreground="{StaticResource TextMuted}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding ClearCompletedDownloadsCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource TextMuted}" FontSize="11"
                                            Cursor="Hand" Padding="8,3" ToolTip="Clear finished downloads">
                                        <TextBlock Text="Clear done"/>
                                    </Button>
                                    <Button Command="{Binding OpenDownloadFolderCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource AccentBlue}" FontSize="13"
                                            Cursor="Hand" Padding="6,3" ToolTip="Open Downloads folder">
                                        <TextBlock Text="📂"/>
                                    </Button>
                                    <Button Command="{Binding ToggleDownloadsTrayCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource TextMuted}" FontSize="14"
                                            Cursor="Hand" Padding="6,3" ToolTip="Close">
                                        <TextBlock Text="✕"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Download items list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Downloads}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,8"
                                                BorderBrush="#1E1E3A" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Filename -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Action Buttons Row -->
                                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <!-- Pause -->
                                                    <Button Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" Foreground="#A0A0A0" Cursor="Hand"
                                                            Padding="4,0" ToolTip="Pause"
                                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="॥" FontSize="11" FontWeight="Bold"/>
                                                    </Button>
                                                    
                                                    <!-- Resume -->
                                                    <Button Command="{Binding DataContext.ResumeDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource AccentBlue}" Cursor="Hand"
                                                            Padding="4,0" ToolTip="Resume"
                                                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="▶" FontSize="11"/>
                                                    </Button>
                                                    
                                                    <!-- Cancel -->
                                                    <Button Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="#FF5370" Cursor="Hand"
                                                            Padding="6,0" ToolTip="Cancel / Remove">
                                                        <TextBlock Text="✕" FontSize="12"/>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Custom progress bar (Grid-based, avoids Win theme issues) -->
                                                <Grid Grid.Row="1" Grid.ColumnSpan="2"
                                                      x:Name="ProgressTrack"
                                                      Height="4" Margin="0,5,0,0">
                                                    <Border CornerRadius="2" Background="#1A1A2E"/>
                                                    <Border CornerRadius="2" Background="#4F8EF7"
                                                            HorizontalAlignment="Left">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource ProgressToWidthMultiConverter}">
                                                                <Binding Path="Progress"/>
                                                                <Binding ElementName="ProgressTrack" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Grid>

                                                <!-- Speed / size / status row -->
                                                <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="11" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding SpeedText}"
                                                               Foreground="{StaticResource AccentBlue}"
                                                               FontSize="11" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding SizeText}"
                                                               Foreground="{StaticResource TextMuted}"
                                                               FontSize="11" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             LAYER 1 — EMBEDDED PLAYER
             Spans columns 1+2 (over categories+streams), sidebar stays visible.
             Collapsed when no stream is playing.
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="PlayerPanel"
              Margin="220,0,0,0"
              Visibility="Collapsed"
              Background="Black"
              PreviewMouseMove="Player_MouseMove">

            <!-- FlyleafHost natively composes into WPF Visual Tree (No HwndHost airspace bugs) -->
            <!-- Player is assigned in code-behind after layout is measured (prevents 0x0 D3D init) -->
            <fl:FlyleafHost x:Name="VideoView"
                            Background="Black"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />

            <!-- Airspace-safe Popup Overlay for HwndHost -->
            <Popup x:Name="PlayerOverlayPopup"
                   PlacementTarget="{Binding ElementName=VideoView}"
                   Placement="Center"
                   AllowsTransparency="True"
                   Width="{Binding ActualWidth, ElementName=VideoView}"
                   Height="{Binding ActualHeight, ElementName=VideoView}">
                
                <!-- Overlay Background -->
                <Grid Background="#01000000"
                      PreviewMouseMove="Player_MouseMove"
                      MouseLeftButtonDown="Player_MouseLeftButtonDown">

                    <!-- Buffering -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#99000000" CornerRadius="12" Padding="24,16"
                            Visibility="{Binding PlayerVm.IsBuffering,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x23F3;" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PlayerVm.StatusText}"
                                       Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Error -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#99200000" CornerRadius="12" Padding="24,16"
                            Visibility="{Binding PlayerVm.ErrorText,
                                         Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="&#x26A0; Playback Error" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource ErrorRed}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding PlayerVm.ErrorText}"
                                       Foreground="#FFDDDD" FontSize="13"
                                       TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- TOP BAR -->
                    <Border x:Name="PlayerTopBar"
                            VerticalAlignment="Top" HorizontalAlignment="Stretch"
                            Opacity="0" IsHitTestVisible="False"
                            MouseEnter="PlayerBar_MouseEnter" MouseLeave="PlayerBar_MouseLeave"
                            Padding="12,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#CC000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Back to browse -->
                            <Button Grid.Column="0" Style="{StaticResource CtrlBtn}"
                                    Click="BackToLibrary_Click" ToolTip="Back to library">
                                <TextBlock Text="&#x2190;" FontSize="18"/>
                            </Button>

                            <!-- Channel info -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="12,0">
                                <Image Source="{Binding PlayerVm.StreamIconUrl}"
                                       Width="26" Height="26"
                                       RenderOptions.BitmapScalingMode="LowQuality"
                                       Margin="0,0,8,0">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="Source" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="{Binding PlayerVm.StreamTitle}"
                                           Foreground="White" FontSize="15" FontWeight="SemiBold"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Fullscreen -->
                            <Button Grid.Column="2" Style="{StaticResource CtrlBtn}"
                                    Command="{Binding PlayerVm.ToggleFullscreenCommand}"
                                    ToolTip="Toggle fullscreen (F)">
                                <TextBlock Text="&#x26F6;" FontSize="18"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- BOTTOM BAR -->
                    <Border x:Name="PlayerBottomBar"
                            VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                            Opacity="0" IsHitTestVisible="False"
                            MouseEnter="PlayerBar_MouseEnter" MouseLeave="PlayerBar_MouseLeave"
                            Padding="16,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Seekbar -->
                            <Grid Grid.Row="0" Margin="0,0,0,10"
                                  Visibility="{Binding PlayerVm.IsSeekable,
                                               Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding PlayerVm.PositionText}"
                                           Foreground="White" FontSize="12" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1"
                                        Minimum="0" Maximum="1" Value="{Binding PlayerVm.Position, Mode=OneWay}"
                                        SmallChange="0.001" LargeChange="0.05"
                                        IsMoveToPointEnabled="True"
                                        Thumb.DragStarted="SeekSlider_DragStarted"
                                        Thumb.DragCompleted="SeekSlider_DragCompleted"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource AccentBlue}"/>
                                <TextBlock Grid.Column="2" Text="{Binding PlayerVm.LengthText}"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Controls -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.SkipBackwardCommand}"
                                            Margin="0,0,4,0" ToolTip="Skip Backward 5s (Left Arrow)">
                                        <TextBlock Text="&#x23EA;" FontSize="12"/>
                                    </Button>
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.TogglePlayCommand}"
                                            Margin="0,0,4,0" ToolTip="Play / Pause (Space)">
                                        <TextBlock FontSize="16">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#x25B6;"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlayerVm.IsPlaying}" Value="True">
                                                            <Setter Property="Text" Value="&#x23F8;"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.SkipForwardCommand}"
                                            Margin="0,0,8,0" ToolTip="Skip Forward 5s (Right Arrow)">
                                        <TextBlock Text="&#x23E9;" FontSize="12"/>
                                    </Button>
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.StopCommand}"
                                            Margin="0,0,14,0" ToolTip="Stop">
                                        <TextBlock Text="&#x23F9;" FontSize="16"/>
                                    </Button>
                                    <TextBlock Text="{Binding PlayerVm.StatusText}"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="12" VerticalAlignment="Center"
                                               Visibility="{Binding PlayerVm.StatusText,
                                                            Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                </StackPanel>

                                <!-- Right -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    
                                    <!-- Settings -->
                                    <Border Background="#1A1A2E" CornerRadius="6" Padding="6,2" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="SPEED:" Foreground="{StaticResource TextMuted}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox Width="55" Margin="0,0,8,0" Foreground="Black"
                                                      ItemsSource="{Binding PlayerVm.PlaybackSpeeds}"
                                                      SelectedItem="{Binding PlayerVm.SelectedSpeed, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat='{}{0}x'}" Foreground="Black"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            
                                            <TextBlock Text="DUB:" Foreground="{StaticResource TextMuted}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox Width="90" Margin="0,0,8,0"
                                                      ItemsSource="{Binding PlayerVm.AudioStreams}"
                                                      SelectedItem="{Binding PlayerVm.SelectedAudioStream, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock>
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0} ({1})">
                                                                    <Binding Path="Language" />
                                                                    <Binding Path="Codec" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            
                                            <TextBlock Text="SUB:" Foreground="{StaticResource TextMuted}"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox Width="90"
                                                      ItemsSource="{Binding PlayerVm.DisplaySubtitleStreams}"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding PlayerVm.SelectedSubtitleStream, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.ToggleMuteCommand}"
                                            Margin="0,0,8,0" ToolTip="Toggle mute (M)">
                                        <TextBlock Text="&#x1F50A;" FontSize="14"/>
                                    </Button>
                                    <Slider Minimum="0" Maximum="100"
                                            Value="{Binding PlayerVm.Volume}"
                                            Width="80" VerticalAlignment="Center"
                                            Foreground="{StaticResource AccentBlue}"
                                            IsMoveToPointEnabled="True"
                                            ToolTip="Volume"/>
                                    <TextBlock Text="{Binding PlayerVm.Volume, StringFormat='{}{0}%'}"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="5,0,0,0" VerticalAlignment="Center" Width="36"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Popup>
        </Grid>
        <!-- end PlayerPanel -->

    </Grid>
</Window>
