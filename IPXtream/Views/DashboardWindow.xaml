<Window x:Class="IPXtream.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:fl="clr-namespace:FlyleafLib.Controls.WPF;assembly=FlyleafLib"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="IPXtream"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <sys:Int32 x:Key="Limit0">0</sys:Int32>
        <sys:Int32 x:Key="Limit256">256</sys:Int32>
        <sys:Int32 x:Key="Limit512">512</sys:Int32>
        <sys:Int32 x:Key="Limit1024">1024</sys:Int32>
        <sys:Int32 x:Key="Limit2048">2048</sys:Int32>
        <sys:Int32 x:Key="Limit5120">5120</sys:Int32>
        <sys:Int32 x:Key="Limit10240">10240</sys:Int32>
        <SolidColorBrush x:Key="BgDeep"       Color="#0F0F1A"/>
        <SolidColorBrush x:Key="BgSidebar"    Color="#12122A"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1A1A2E"/>
        <SolidColorBrush x:Key="BgHover"      Color="#22224A"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#4F8EF7"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7C5CBF"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#888899"/>
        <SolidColorBrush x:Key="InputBg"      Color="#12122A"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#2E2E50"/>
        <SolidColorBrush x:Key="DividerColor" Color="#1E1E3A"/>
        <SolidColorBrush x:Key="ErrorRed"     Color="#FF5370"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#4EC994"/>

        <CollectionViewSource x:Key="GroupedDownloads" Source="{Binding Downloads}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <!-- ── Category list item ──────────────────────────────────────────── -->
        <Style x:Key="CategoryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stream card ────────────────────────────────────────────────── -->
        <Style x:Key="StreamItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="{TemplateBinding Margin}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- ── Search TextBox ──────────────────────────────────────────────── -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBlue}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock Text="Search channels, movies, and series..." 
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Opacity="0.5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Focusable="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Play button ────────────────────────────────────────────────── -->
        <Style x:Key="PlayBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Player control button ──────────────────────────────────────── -->
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Width"           Value="38"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="19" Background="#55FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#AAFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stream Card DataTemplate ────────────────────────────────────── -->
        <DataTemplate x:Key="StreamCardTemplate">
            <Border Width="150" Height="220" CornerRadius="12" Background="{DynamicResource BgSidebar}" 
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <!-- Poster -->
                    <Image Source="{Binding StreamIcon, Converter={StaticResource CachedImageConverter}}"
                           Stretch="UniformToFill">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <Trigger Property="Source" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    
                    <!-- Fallback empty state icon -->
                    <Path Data="{StaticResource IconTv}" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StreamIcon}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StreamIcon}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>

                    <!-- Dark Gradient for Text -->
                    <Border VerticalAlignment="Bottom" Height="80">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#E60D0D1A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    
                    <TextBlock Text="{Binding Name}"
                               Foreground="White" FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="36"
                               Margin="10,0,10,12" VerticalAlignment="Bottom" HorizontalAlignment="Center" TextAlignment="Center"/>

                    <!-- Hover Overlay with Buttons -->
                    <Border x:Name="HoverOverlay" Background="#99000000" Opacity="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- Play -->
                            <Button Width="44" Height="44" Padding="0" FontSize="18" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                    Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PlayBd" CornerRadius="22">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Path Data="{StaticResource IconPlay}" Style="{StaticResource VectorIconFilled}" Width="16" Height="16" Margin="2,0,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PlayBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- Download -->
                            <Button Margin="12,0,0,0" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding IsDownloadable, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Download to ~/Downloads/IPXtream/&#x0a;(Includes all embedded subtitles automatically)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DlBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path Data="{StaticResource IconDownloads}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DlBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- About Movie Info Button -->
                            <Button Margin="12,0,0,0" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding IsMovie, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ShowMovieInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="About Movie">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="InfoBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path Data="{StaticResource IconInfo}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="InfoBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Toggle Featured (Star Button) -->
                            <Button Margin="12,0,0,0" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ToggleFeaturedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Add / Remove from What's new?">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="StarBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path x:Name="StarPath" Data="{StaticResource IconStar}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="StarBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsFeatured}" Value="True">
                                                <Setter TargetName="StarPath" Property="Fill" Value="#FFD700"/>
                                                <Setter TargetName="StarPath" Property="Stroke" Value="#FFD700"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Toggle Dev Recommendation (Heart Button) -->
                            <Button Margin="12,0,0,0" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ToggleDevRecommendationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Mark / Unmark as Dev Recommendation">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="HeartBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path x:Name="HeartPath" Data="{StaticResource IconHeart}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeartBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsDevRecommendation}" Value="True">
                                                <Setter TargetName="HeartPath" Property="Fill" Value="#FF4A5A"/>
                                                <Setter TargetName="HeartPath" Property="Stroke" Value="#FF4A5A"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ── ComboBox item style for Settings ──────────────────────────── -->
        <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E50"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4F8EF7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox style for Settings ───────────────────────────────── -->
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Background="{TemplateBinding Background}"
                                          Grid.Column="2"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Grid HorizontalAlignment="Right" Width="30">
                                                <Path x:Name="Arrow"
                                                      Fill="{DynamicResource TextMuted}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource InputBg}"
                                            BorderBrush="{DynamicResource InputBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,2,0,0">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox item style for Player Controls ───────────────────── -->
        <Style x:Key="PlayerComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E50"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox style for Player Controls ────────────────────────── -->
        <Style x:Key="PlayerComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource PlayerComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Background="{TemplateBinding Background}"
                                          Grid.Column="2"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid HorizontalAlignment="Right" Width="18">
                                                <Path x:Name="Arrow"
                                                      Fill="{DynamicResource TextMuted}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 3.5 3.5 L 7 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,0,18,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource InputBg}"
                                            BorderBrush="{DynamicResource InputBorder}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,2,0,0">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="50"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle Switch style for CheckBox ────────────────────────────── -->
        <Style x:Key="ToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="#2E2E50"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Track"
                                    Width="44" Height="22"
                                    CornerRadius="11"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource InputBorder}"
                                    BorderThickness="1">
                                <Ellipse x:Name="Thumb"
                                         Width="16" Height="16"
                                         Fill="#888899"
                                         HorizontalAlignment="Left"
                                         Margin="2,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Setter TargetName="Thumb" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform X="20"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── Window load animation ──────────────────────────────────────────────── -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.35"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!--
        Root Grid has two layers:
          [0] Dashboard content (sidebar + categories + streams)
          [1] Player panel — hidden by default, slides over the content area (columns 1+2)
              when a stream is playing. Sidebar stays visible.
    -->
    <Grid Background="{DynamicResource BgDeep}">

        <!-- ══════════════════════════════════════════════════════════════════
             LAYER 0 — DASHBOARD
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="DashboardGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="230">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="230"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="CurrentlyWatching">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Settings">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════ SIDEBAR ══════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="{DynamicResource BgSidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,24,20,20">
                        <Border Width="36" Height="36" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="{StaticResource IconLogo}" Fill="White" Stretch="Uniform" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="IPXtream" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Nav -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="live"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=LiveTV}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconTv}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Live TV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="vod"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=VOD}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconMovies}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Movies" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="series"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=Series}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconSeries}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Series" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="whatsnew"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=WhatsNew}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconNew}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="What's new?" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="currentlywatching"
                                Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=CurrentlyWatching}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconEye}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Currently Watching" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="16,16"/>

                        <!-- Cache / Cancel toggle -->
                        <Button Style="{StaticResource NavBtn}" Command="{Binding CacheAllBackgroundCommand}"
                                Visibility="{Binding IsCachingAll, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCloud}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Cache Entire Library" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavBtn}" Command="{Binding CancelCacheCommand}"
                                Visibility="{Binding IsCachingAll, Converter={StaticResource BoolToVisibilityConverter}}"
                                Foreground="#FF5370">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCancel}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Cancel Caching" VerticalAlignment="Center"
                                           Foreground="#FF5370"/>
                            </StackPanel>
                        </Button>

                        <!-- Downloads nav tab with active badge -->
                        <Button Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=Downloads}"
                                Command="{Binding SelectSectionCommand}" CommandParameter="downloads"
                                Margin="0,4,0,0">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconDownloads}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="Downloads" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Active download count badge -->
                                <Border Background="{DynamicResource AccentBlue}" CornerRadius="8"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Padding="5,1" Margin="0,0,8,0"
                                        Visibility="{Binding HasActiveDownloads,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ActiveDownloadCount}"
                                               FontSize="10" Foreground="White"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Button>

                        <Button Style="{Binding ActiveSection,
                                        Converter={StaticResource SectionToStyleConverter},
                                        ConverterParameter=Settings}"
                                Command="{Binding SelectSectionCommand}" CommandParameter="settings"
                                Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconSettings}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Command="{Binding RefreshCommand}" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconRefresh}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Refresh Current View" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Command="{Binding LogoutCommand}" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconLogout}" Style="{StaticResource VectorIcon}" Width="16" Height="16" Margin="0,0,10,0"/>
                                <TextBlock Text="Logout" VerticalAlignment="Center"
                                           Foreground="{StaticResource ErrorRed}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- User footer -->
                    <Border Grid.Row="2" Background="{DynamicResource BgCard}"
                            CornerRadius="12" Margin="12,0,12,16" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayUsername}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ServerDisplay}"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="11" Margin="0,2,0,0"/>

                            <!-- Version + Update row -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Version label -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding AppVersion}"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="10" VerticalAlignment="Center"
                                           Cursor="Hand" MouseDown="Version_MouseDown"/>

                                <!-- Check for Updates button -->
                                <Button Grid.Column="1"
                                        Command="{Binding CheckForUpdatesCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="4,1" ToolTip="Check for updates">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="IsEnabled" Value="True"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource AccentBlue}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Check"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                                                        <Setter Property="Text" Value="…"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <!-- Update status (shown after check) -->
                            <TextBlock Text="{Binding UpdateStatus}"
                                       FontSize="10" Margin="0,3,0,0" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding UpdateStatus}" Value=""/>
                                                </MultiDataTrigger.Conditions>
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding UpdateStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Clickable "open release page" — only shows when update is available -->
                            <Button Command="{Binding DownloadAndInstallUpdateCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="0,2" HorizontalAlignment="Left"
                                    ToolTip="Download and install update">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <!-- Show if update URL is present AND not currently downloading -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding UpdateUrl, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible"/>
                                                    <Condition Binding="{Binding IsDownloadingUpdate}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="→ Download now"
                                           FontSize="10"
                                           Foreground="{StaticResource AccentGreen}"
                                           TextDecorations="Underline"/>
                            </Button>

                            <!-- In-app Download Progress Panel -->
                            <StackPanel Margin="0,4,0,0" Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding UpdateDownloadStatus}"
                                           FontSize="10" Foreground="{DynamicResource AccentBlue}"
                                           Margin="0,0,0,4"/>
                                <ProgressBar Height="4" Minimum="0" Maximum="1"
                                             Value="{Binding UpdateDownloadProgress, Mode=OneWay}"
                                             Background="#1F1F3D" Foreground="{DynamicResource AccentBlue}"
                                             BorderThickness="0"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                </Grid>
            </Border>

            <!-- ══════════ CATEGORIES ════════════════════════════════════════ -->
            <Border x:Name="CategoriesPanel" Grid.Column="1" Background="{DynamicResource BgDeep}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,1,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="CurrentlyWatching">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="Settings">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16,16,16,12">
                        <StackPanel>
                            <TextBlock Text="CATEGORIES"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="Loading…"
                                       Foreground="{DynamicResource AccentBlue}"
                                       FontSize="12" Margin="0,4,0,0"
                                       Visibility="{Binding IsLoadingCategories,
                                                    Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource CategoryItemStyle}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding CategoryName}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Error + Retry -->
                    <Border Grid.Row="1" VerticalAlignment="Top"
                            Background="#441A0A" CornerRadius="8"
                            Padding="10,8" Margin="8,4"
                            Visibility="{Binding ErrorMessage,
                                         Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#FF7B6B" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <Button Command="{Binding SelectSectionCommand}" CommandParameter="live"
                                    Background="#4F8EF7" Foreground="White"
                                    BorderThickness="0" Padding="8,4"
                                    FontSize="11" FontWeight="Bold" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                &#x21BA; Retry
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════ STREAMS ═══════════════════════════════════════════ -->
            <Grid x:Name="StreamsPanel" Grid.Column="2" Background="{DynamicResource BgDeep}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="Settings">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: Toolbar -->
                    <RowDefinition Height="Auto"/>  <!-- 1: Series Details Banner -->
                    <RowDefinition Height="Auto"/>  <!-- 2: Seasons tabs -->
                    <RowDefinition Height="Auto"/>  <!-- 3: Hero Banner -->
                    <RowDefinition Height="*"/>     <!-- 4: Stream card grid -->
                    <RowDefinition Height="Auto"/>  <!-- 5: Status bar -->
                    <RowDefinition Height="Auto"/>  <!-- 6: Downloads tray -->
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" Height="38"
                                 Foreground="White"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedCategory.CategoryName}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="16,0,0,0"
                                   Visibility="{Binding HasSelectedCategory,
                                                Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- Error banner -->
                <Border Grid.Row="0" VerticalAlignment="Bottom"
                        Background="#3DFF5370" CornerRadius="8"
                        Padding="12,6" Margin="16,0,16,4"
                        Visibility="{Binding ErrorMessage,
                                     Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorRed}" FontSize="12"/>
                </Border>

                <!-- Series Details Banner -->
                <Border Grid.Row="1" Background="#121225" CornerRadius="10" Margin="16,0,16,10" Padding="16" ClipToBounds="True"
                        Visibility="{Binding IsViewingSeriesInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <!-- Blur Background cover -->
                        <Image Source="{Binding CurrentSeries.Info.Cover}" Stretch="UniformToFill" Opacity="0.15"
                               Width="{Binding ElementName=SeriesDetailsContentGrid, Path=ActualWidth}"
                               Height="{Binding ElementName=SeriesDetailsContentGrid, Path=ActualHeight}">
                            <Image.Effect>
                                <BlurEffect Radius="20"/>
                            </Image.Effect>
                        </Image>

                        <Grid x:Name="SeriesDetailsContentGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Back button and title -->
                                <RowDefinition Height="*"/>    <!-- Content grid (Cover + Info) -->
                            </Grid.RowDefinitions>

                            <!-- Header: Back button + Title -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource NavBtn}"
                                        Command="{Binding BackToSeriesCommand}"
                                        Content="⬅ Back" Padding="12,6" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSeries.Info.Name}" 
                                           Foreground="White" FontSize="20" FontWeight="Bold" 
                                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>

                            <!-- Content Grid -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- Cover image -->
                                    <ColumnDefinition Width="*"/>    <!-- Info text -->
                                </Grid.ColumnDefinitions>

                                <!-- Cover Image -->
                                <Border Grid.Column="0" Width="100" Height="150" CornerRadius="6" ClipToBounds="True"
                                        BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Top">
                                    <Image Source="{Binding CurrentSeries.Info.Cover, Converter={StaticResource CachedImageConverter}}" Stretch="UniformToFill"/>
                                </Border>

                                <!-- Info Text -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <!-- Director / Cast -->
                                    <WrapPanel Margin="0,0,0,8">
                                        <TextBlock Text="Director: " Foreground="{DynamicResource AccentBlue}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentSeries.Info.Director}" Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                                        <TextBlock Text="Cast: " Foreground="{DynamicResource AccentBlue}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentSeries.Info.Cast}" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                                    </WrapPanel>

                                    <!-- Plot -->
                                    <TextBlock Text="Overview" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CurrentSeries.Info.Plot}" Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap" LineHeight="16"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Seasons Tabs -->
                <Border Grid.Row="2" BorderThickness="0,1,0,1" BorderBrush="#1C1C28" Margin="0,0,0,10"
                        Visibility="{Binding IsViewingSeriesInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox ItemsSource="{Binding Seasons}" SelectedItem="{Binding SelectedSeason}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0" Padding="14,0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="16,10"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border BorderThickness="0,0,0,3" BorderBrush="Transparent" x:Name="Bd" Background="{TemplateBinding Background}">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1A1A2E"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- 16:9 Hero Banner (Auto-rotating What's New Carousel) -->
                <Border x:Name="HeroBanner" Grid.Row="3" Height="280" CornerRadius="10" Margin="16,0,16,10" ClipToBounds="True" Background="#121225">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowHeroBanner}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- Cover Background (Stretch to Fill) -->
                        <Image Source="{Binding FeaturedCarouselItem.Cover}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image.Effect>
                                <BlurEffect Radius="15" RenderingBias="Quality"/>
                            </Image.Effect>
                        </Image>
                        
                        <!-- Overlay Dark Grid for Premium Contrast -->
                        <Border Background="#990F0F1D"/>

                        <!-- Actual 16:9 Poster Image + Details Grid -->
                        <Grid x:Name="BannerContent" Margin="24">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <!-- Smooth fade animation when Carousel item changes -->
                                        <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.3" To="1.0" Duration="0:0:0.5"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Poster image -->
                                <ColumnDefinition Width="*"/>    <!-- Text details -->
                            </Grid.ColumnDefinitions>

                            <!-- Highlighted Poster -->
                            <Border Grid.Column="0" Width="150" CornerRadius="6" ClipToBounds="True" Background="#0A0A16"
                                    BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,24,0">
                                <Image Source="{Binding FeaturedCarouselItem.StreamIcon, Converter={StaticResource CachedImageConverter}, NotifyOnTargetUpdated=True}" 
                                       Stretch="UniformToFill"/>
                            </Border>

                            <!-- Text Details -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Tag / Rating -->
                                    <RowDefinition Height="Auto"/> <!-- Title -->
                                    <RowDefinition Height="*"/>    <!-- Plot -->
                                    <RowDefinition Height="Auto"/> <!-- Play/Download Buttons -->
                                </Grid.RowDefinitions>

                                <!-- Tag -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#FFD700" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconStar}" Fill="#0F0F1A" Width="9" Height="9" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="WHAT'S NEW" Foreground="#0F0F1A" FontSize="10" FontWeight="Black" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding FeaturedCarouselItem.ReleaseDate}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Path Data="{StaticResource IconStar}" Fill="#FFD700" Width="10" Height="10" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding FeaturedCarouselItem.Rating}" Foreground="White" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Title -->
                                <TextBlock Grid.Row="1" Text="{Binding FeaturedCarouselItem.Name}" Foreground="White" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <!-- Plot -->
                                <TextBlock Grid.Row="2" Text="{Binding FeaturedCarouselItem.Plot}" Foreground="{DynamicResource TextMuted}" FontSize="13" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,0,48,16" LineHeight="18"/>

                                <!-- Buttons -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                    <Button Command="{Binding PlayCommand}" CommandParameter="{Binding FeaturedCarouselItem}"
                                            Background="#4F8EF7" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="20,8" Margin="0,0,12,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="PlayBd" CornerRadius="6" Background="{TemplateBinding Background}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                        <Path Data="{StaticResource IconPlay}" Style="{StaticResource VectorIconFilled}" Width="12" Height="12" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Play" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="PlayBd" Property="Background" Value="#3B7AE3"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Download button (Only visible if downloadable) -->
                                    <Button Command="{Binding DownloadCommand}" CommandParameter="{Binding FeaturedCarouselItem}"
                                            Visibility="{Binding FeaturedCarouselItem.IsDownloadable, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="#2C2C3E" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="20,8">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="DlBd" CornerRadius="6" Background="{TemplateBinding Background}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                        <Path Data="{StaticResource IconDownload}" Style="{StaticResource VectorIconFilled}" Width="12" Height="12" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Download" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DlBd" Property="Background" Value="#3D3D52"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Carousel Indicators (Dots) -->
                        <ItemsControl ItemsSource="{Binding FeaturedItems}" 
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                                      Margin="0,0,24,24">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.SelectCarouselItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Margin="4,0" Width="20" Height="10" Cursor="Hand" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Border x:Name="Dot" CornerRadius="3" Background="#55FFFFFF" Width="6" Height="6"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelectedCarousel}" Value="True">
                                                        <Setter TargetName="Dot" Property="Background" Value="#4F8EF7"/>
                                                        <Setter TargetName="Dot" Property="Width" Value="16"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Dot" Property="Background" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Stream card grid -->
                <ListBox Grid.Row="4"
                         ItemsSource="{Binding Streams}"
                         SelectedItem="{Binding SelectedStream}"
                         ItemContainerStyle="{StaticResource StreamItemStyle}"
                         ItemTemplate="{StaticResource StreamCardTemplate}"
                         Background="Transparent" BorderThickness="0" Padding="10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding PlayCommand}"
                                      CommandParameter="{Binding SelectedStream}"/>
                    </ListBox.InputBindings>
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <!-- Show when browsing a normal category (not WhatsNew, not Downloads) -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="LiveTV"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="VOD"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="Series"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="CurrentlyWatching"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <!-- Always show when viewing series episodes, regardless of ActiveSection -->
                                <DataTrigger Binding="{Binding IsViewingSeriesInfo}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <!-- What's New Grouped ScrollViewer (only visible when ActiveSection == WhatsNew) -->
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsViewingSeriesInfo}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <!-- Admin Control Panel for What's New -->
                        <Border Background="{DynamicResource BgCard}" CornerRadius="8" Padding="16,12" Margin="10,0,10,20"
                                Visibility="{Binding IsAdminMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <Path Data="{StaticResource IconSettings}" Stroke="{DynamicResource AccentBlue}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="WHAT'S NEW EDITOR (ADMIN MODE)" Foreground="{DynamicResource AccentBlue}" FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="Add or remove items using Star (Whats New) and Heart (Dev Recommendation) buttons on any stream card." Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" Command="{Binding PushWhatsNewCommand}"
                                        Background="#4F8EF7" Foreground="White" FontWeight="Bold" FontSize="12"
                                        Padding="16,8" Cursor="Hand" VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBd" CornerRadius="6" Background="{TemplateBinding Background}">
                                                <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBd" Property="Background" Value="#668EF7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    Push to All Users
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 1. Dev Recommendations Section -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DevRecommendations.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconHeart}" Stroke="#FF4A5A" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Dev Recommendations" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding DevRecommendations}" SelectedItem="{Binding SelectedStream}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedStream}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- 2. Live TV Section -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FeaturedLive.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconTv}" Stroke="{DynamicResource AccentBlue}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Live TV" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding FeaturedLive}" SelectedItem="{Binding SelectedStream}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedStream}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- 3. Shows / Series Section -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FeaturedShows.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconSeries}" Stroke="{DynamicResource AccentBlue}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="TV Shows" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding FeaturedShows}" SelectedItem="{Binding SelectedStream}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedStream}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- 4. Movies Section -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FeaturedMovies.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconMovies}" Stroke="{DynamicResource AccentBlue}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Movies" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding FeaturedMovies}" SelectedItem="{Binding SelectedStream}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedStream}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="{Binding HasSelectedCategory,
                                     Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            <Style.Triggers>
                                <!-- Hide empty state when viewing series episodes -->
                                <DataTrigger Binding="{Binding IsViewingSeriesInfo}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <!-- Hide empty state when in What's New section -->
                                <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <!-- Hide empty state when in Downloads section -->
                                <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Path Data="{StaticResource IconPointer}" Fill="{DynamicResource TextMuted}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Select a category to browse"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="16" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Loading overlay -->
                <Border Grid.Row="1" Grid.RowSpan="4" Background="#88000000"
                        Visibility="{Binding IsLoadingStreams,
                                     Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Loading streams…"
                               Foreground="{DynamicResource AccentBlue}"
                               FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Status bar -->
                <Border Grid.Row="5" Background="{DynamicResource BgCard}"
                        BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,1,0,0"
                        Padding="16,4">
                    <Grid>
                        <!-- Left side: Status Message -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource TextMuted}" FontSize="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        
                        <!-- Right side: Pagination Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PageStatusText}"
                                       Foreground="{DynamicResource TextMuted}" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            
                            <!-- Previous button -->
                            <Button Command="{Binding GoToPreviousPageCommand}"
                                    IsEnabled="{Binding HasPreviousPage}"
                                    Width="24" Height="20" Padding="0"
                                    Foreground="White" Background="#2C2C3E" BorderThickness="0" Cursor="Hand"
                                    Margin="0,0,6,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}">
                                            <Path Data="{StaticResource IconPrev}" Fill="White" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3D3D52"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- Next button -->
                            <Button Command="{Binding GoToNextPageCommand}"
                                    IsEnabled="{Binding HasNextPage}"
                                    Width="24" Height="20" Padding="0"
                                    Foreground="White" Background="#2C2C3E" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}">
                                            <Path Data="{StaticResource IconNext}" Fill="White" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3D3D52"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Downloads tray ─────────────────────────────────────── -->
                <Border Grid.Row="6" Background="#0D0D1E"
                        BorderBrush="{DynamicResource AccentBlue}" BorderThickness="0,1,0,0"
                        Visibility="{Binding ShowDownloadsTray,
                                     Converter={StaticResource BoolToVisibilityConverter}}"
                        MaxHeight="240">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tray header -->
                        <Border Grid.Row="0" Padding="14,7" Background="#12122A">
                            <Grid>
                                <TextBlock Text="DOWNLOADS" Foreground="{DynamicResource TextMuted}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Command="{Binding ClearCompletedDownloadsCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource TextMuted}" FontSize="11"
                                            Cursor="Hand" Padding="8,3" ToolTip="Clear finished downloads">
                                        <TextBlock Text="Clear done"/>
                                    </Button>
                                    <Button Command="{Binding OpenDownloadFolderCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource AccentBlue}" FontSize="13"
                                            Cursor="Hand" Padding="6,3" ToolTip="Open Downloads folder">
                                        <Path Data="{StaticResource IconFolder}" Fill="{DynamicResource AccentBlue}" Width="14" Height="14" Stretch="Uniform"/>
                                    </Button>
                                    <Button Command="{Binding ToggleDownloadsTrayCommand}"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource TextMuted}" FontSize="14"
                                            Cursor="Hand" Padding="6,3" ToolTip="Close">
                                        <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextMuted}" Width="12" Height="12" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Download items list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Downloads}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,8"
                                                BorderBrush="#1E1E3A" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Filename -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Action Buttons Row -->
                                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <!-- Pause -->
                                                    <Button Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" Foreground="#A0A0A0" Cursor="Hand"
                                                            Padding="4,0" ToolTip="Pause"
                                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Path Data="{StaticResource IconPause}" Fill="#A0A0A0" Width="10" Height="10" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Resume -->
                                                    <Button Command="{Binding DataContext.ResumeDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentBlue}" Cursor="Hand"
                                                            Padding="4,0" ToolTip="Resume"
                                                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Path Data="{StaticResource IconPlay}" Fill="{DynamicResource AccentBlue}" Width="10" Height="10" Stretch="Uniform"/>
                                                    </Button>
                                                    
                                                    <!-- Cancel -->
                                                    <Button Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="#FF5370" Cursor="Hand"
                                                            Padding="6,0" ToolTip="Cancel / Remove">
                                                        <Path Data="{StaticResource IconClose}" Fill="#FF5370" Width="10" Height="10" Stretch="Uniform"/>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Custom progress bar (Grid-based, avoids Win theme issues) -->
                                                <Grid Grid.Row="1" Grid.ColumnSpan="2"
                                                      x:Name="ProgressTrack"
                                                      Height="4" Margin="0,5,0,0">
                                                    <Border CornerRadius="2" Background="#1A1A2E"/>
                                                    <Border CornerRadius="2" Background="#4F8EF7"
                                                            HorizontalAlignment="Left">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource ProgressToWidthMultiConverter}">
                                                                <Binding Path="Progress"/>
                                                                <Binding ElementName="ProgressTrack" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </Grid>

                                                <!-- Speed / size / status row -->
                                                <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               FontSize="11" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding SpeedText}"
                                                               Foreground="{DynamicResource AccentBlue}"
                                                               FontSize="11" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding SizeText}"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               FontSize="11" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════ DOWNLOADS PANEL ═══════════════════════════════════ -->
            <Grid x:Name="DownloadsPanel" Grid.Column="2" Background="{DynamicResource BgDeep}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar/Settings Header -->
                <Border Grid.Row="0" Padding="20,16" Background="{DynamicResource BgSidebar}"
                        BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="DOWNLOADS MANAGER" Foreground="White" FontSize="16" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Download folder: " Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DownloadFolder}" Foreground="{DynamicResource AccentBlue}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding ChangeDownloadFolderCommand}"
                                    Background="#1A1A2E" BorderBrush="#2E2E50" BorderThickness="1"
                                    Foreground="White" Cursor="Hand" Padding="12,6" Height="32">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconFolder}" Fill="White" Width="12" Height="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="Change Folder" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Command="{Binding OpenDownloadFolderCommand}"
                                    Background="#1A1A2E" BorderBrush="#2E2E50" BorderThickness="1"
                                    Foreground="White" Cursor="Hand" Padding="12,6" Height="32" Margin="8,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconEye}" Fill="White" Width="12" Height="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="Open Folder" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Command="{Binding ClearCompletedDownloadsCommand}"
                                    Background="#1A1A2E" BorderBrush="#2E2E50" BorderThickness="1"
                                    Foreground="White" Cursor="Hand" Padding="12,6" Height="32" Margin="8,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconBroom}" Fill="White" Width="12" Height="12" Margin="0,0,6,0"/>
                                                <TextBlock Text="Clear Done" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Downloads list -->
                <ScrollViewer Grid.Row="1" Padding="20,10" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <!-- List view grouped -->
                        <ListBox ItemsSource="{Binding Source={StaticResource GroupedDownloads}}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Background="#14142B" Padding="14,8" CornerRadius="8" Margin="0,16,0,8"
                                                    BorderBrush="#1E1E3A" BorderThickness="1">
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AccentBlue}"
                                                           FontWeight="Bold" FontSize="13"/>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgCard}" CornerRadius="10" Padding="16,12" Margin="0,0,0,10"
                                            BorderBrush="#252545" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Left side: Title, status info -->
                                            <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Vertical" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                    <TextBlock Text=" • " Foreground="{DynamicResource DividerColor}" FontSize="12"/>
                                                    <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextMuted}" FontSize="12"/>
                                                    <TextBlock Text=" • " Foreground="{DynamicResource DividerColor}" FontSize="12" Visibility="{Binding SpeedText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding SpeedText}" Foreground="{DynamicResource AccentGreen}" FontSize="12" FontWeight="SemiBold" Visibility="{Binding SpeedText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Speed Limit ComboBox -->
                                            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="Limit: " Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                                <ComboBox SelectedValue="{Binding SpeedLimitKbps, Mode=TwoWay}" SelectedValuePath="Tag"
                                                          Background="#12122A" Foreground="White" BorderBrush="#2E2E50"
                                                          Padding="6,4" Width="90" Height="28" VerticalAlignment="Center" FontSize="11">
                                                     <ComboBoxItem Content="Unlimited" Tag="{StaticResource Limit0}"/>
                                                     <ComboBoxItem Content="256 KB/s" Tag="{StaticResource Limit256}"/>
                                                     <ComboBoxItem Content="512 KB/s" Tag="{StaticResource Limit512}"/>
                                                     <ComboBoxItem Content="1 MB/s" Tag="{StaticResource Limit1024}"/>
                                                     <ComboBoxItem Content="2 MB/s" Tag="{StaticResource Limit2048}"/>
                                                     <ComboBoxItem Content="5 MB/s" Tag="{StaticResource Limit5120}"/>
                                                     <ComboBoxItem Content="10 MB/s" Tag="{StaticResource Limit10240}"/>
                                                 </ComboBox>
                                            </StackPanel>

                                            <!-- Controls -->
                                            <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <!-- Pause -->
                                                <Button Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#22224A" BorderThickness="0" Foreground="White" Cursor="Hand"
                                                        Padding="12,6" Height="28" Margin="0,0,6,0" ToolTip="Pause"
                                                        Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Path Data="{StaticResource IconPause}" Fill="White" Width="10" Height="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="Pause" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Resume -->
                                                <Button Command="{Binding DataContext.ResumeDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Background="{DynamicResource AccentBlue}" BorderThickness="0" Foreground="White" Cursor="Hand"
                                                        Padding="12,6" Height="28" Margin="0,0,6,0" ToolTip="Resume"
                                                        Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Path Data="{StaticResource IconPlay}" Fill="White" Width="10" Height="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="Resume" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Stop -->
                                                <Button Command="{Binding DataContext.StopDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#3DFF5370" BorderThickness="0" Foreground="White" Cursor="Hand"
                                                        Padding="12,6" Height="28" Margin="0,0,6,0" ToolTip="Stop and clean up"
                                                        Visibility="{Binding IsCompleted, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Path Data="{StaticResource IconStop}" Fill="White" Width="10" Height="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="Stop" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Remove / Cancel -->
                                                <Button Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#1E1E3A" BorderThickness="0" Foreground="White" Cursor="Hand"
                                                        Padding="8,6" Height="28" ToolTip="Remove from list">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="4" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Path Data="{StaticResource IconClose}" Fill="{DynamicResource TextMuted}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="Remove" FontSize="11" Foreground="{DynamicResource TextMuted}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>

                                            <!-- Progress bar row -->
                                            <Grid Grid.Row="1" Grid.ColumnSpan="3" x:Name="ProgressTrack" Height="6" Margin="0,10,0,2">
                                                <Border CornerRadius="3" Background="#12122A"/>
                                                <Border CornerRadius="3" Background="{DynamicResource AccentBlue}" HorizontalAlignment="Left">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource ProgressToWidthMultiConverter}">
                                                            <Binding Path="Progress"/>
                                                            <Binding ElementName="ProgressTrack" Path="ActualWidth"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty state when no downloads -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,0"
                                    Visibility="{Binding HasDownloads, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Path Data="{StaticResource IconDownload}" Fill="{DynamicResource TextMuted}" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="No downloads in progress" Foreground="{DynamicResource TextMuted}" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Go to Movies or Series and click the download icon to start." Foreground="{DynamicResource TextMuted}" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Movie Details Modal Overlay -->
            <Grid Grid.Column="0" Grid.ColumnSpan="3" Panel.ZIndex="100"
                  Visibility="{Binding IsViewingMovieInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                <!-- Clickable background to close -->
                <Button Command="{Binding CloseMovieInfoCommand}" Background="#CC000000" BorderThickness="0" Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Details Card -->
                <Border Width="650" Height="420" CornerRadius="12" Background="#121225" BorderBrush="#33FFFFFF" BorderThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" ClipToBounds="True">
                    <Grid>
                        <!-- Close Button -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Command="{Binding CloseMovieInfoCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="16" Background="#2C2C3E">
                                        <Path Data="{StaticResource IconClose}" Fill="White" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Content Layout -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/> <!-- Poster -->
                                <ColumnDefinition Width="*"/>   <!-- Info -->
                            </Grid.ColumnDefinitions>

                            <!-- Movie Poster -->
                            <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" BorderBrush="#33FFFFFF" BorderThickness="1" Height="300" VerticalAlignment="Top" Margin="0,0,24,0">
                                <Image Source="{Binding SelectedMovieForInfo.Cover, Converter={StaticResource CachedImageConverter}}" Stretch="UniformToFill"/>
                            </Border>

                            <!-- Movie Info Details -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Title -->
                                    <RowDefinition Height="Auto"/> <!-- Genre / Release date / Rating -->
                                    <RowDefinition Height="Auto"/> <!-- Director / Cast -->
                                    <RowDefinition Height="*"/>    <!-- Plot description -->
                                    <RowDefinition Height="Auto"/> <!-- Action Buttons (Play / Download) -->
                                </Grid.RowDefinitions>

                                <!-- Title -->
                                <TextBlock Grid.Row="0" Text="{Binding SelectedMovieForInfo.Name}" Foreground="White" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,32,10"/>

                                <!-- Metadata info -->
                                <WrapPanel Grid.Row="1" Margin="0,0,0,14">
                                    <Border Background="#FFD700" CornerRadius="4" Padding="5,2" Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconStar}" Fill="#0F0F1A" Width="9" Height="9" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SelectedMovieForInfo.Rating}" Foreground="#0F0F1A" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedMovieForInfo.ReleaseDate}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedMovieForInfo.Genre}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                                </WrapPanel>

                                <!-- Director & Cast -->
                                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                                    <WrapPanel Margin="0,0,0,4">
                                        <TextBlock Text="Director: " Foreground="{DynamicResource AccentBlue}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedMovieForInfo.Director}" Foreground="White" FontSize="12"/>
                                    </WrapPanel>
                                    <TextBlock Text="Cast:" Foreground="{DynamicResource AccentBlue}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding SelectedMovieForInfo.Cast}" Foreground="White" FontSize="12" TextWrapping="Wrap" MaxHeight="48" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Plot -->
                                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                                    <TextBlock Text="{Binding SelectedMovieForInfo.Plot}" Foreground="{DynamicResource TextMuted}" FontSize="13" TextWrapping="Wrap" LineHeight="18"/>
                                </ScrollViewer>

                                <!-- Action Buttons -->
                                <StackPanel Grid.Row="4" Orientation="Horizontal">
                                    <!-- Play Button -->
                                    <Button Command="{Binding PlayCommand}" CommandParameter="{Binding SelectedMovieForInfo}"
                                            Background="#4F8EF7" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="20,8" Margin="0,0,12,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="PlayBd" CornerRadius="6" Background="{TemplateBinding Background}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                        <Path Data="{StaticResource IconPlay}" Style="{StaticResource VectorIconFilled}" Width="12" Height="12" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Play" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="PlayBd" Property="Background" Value="#3B7AE3"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Download Button -->
                                    <Button Command="{Binding DownloadCommand}" CommandParameter="{Binding SelectedMovieForInfo}"
                                            Visibility="{Binding SelectedMovieForInfo.IsDownloadable, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="#2C2C3E" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="20,8">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="DlBd" CornerRadius="6" Background="{TemplateBinding Background}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                        <Path Data="{StaticResource IconDownload}" Style="{StaticResource VectorIconFilled}" Width="12" Height="12" Margin="0,0,8,0"/>
                                                        <TextBlock Text="Download" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DlBd" Property="Background" Value="#3D3D52"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                             </Grid>
                         </Grid>
                     </Grid>
                 </Border>
             </Grid>

            
         </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             LAYER 1 — EMBEDDED PLAYER
             Spans columns 1+2 (over categories+streams), sidebar stays visible.
             Collapsed when no stream is playing.
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="PlayerPanel"
              Margin="220,0,0,0"
              Visibility="Collapsed"
              Background="Black"
              PreviewMouseMove="Player_MouseMove">

            <!-- FlyleafHost natively composes into WPF Visual Tree (No HwndHost airspace bugs) -->
            <!-- Player is assigned in code-behind after layout is measured (prevents 0x0 D3D init) -->
            <fl:FlyleafHost x:Name="VideoView"
                            Background="Black"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Visibility="Collapsed" />

            <!-- VLC VideoView -->
            <vlc:VideoView x:Name="VlcVideoView"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           Visibility="Collapsed" />

            <!-- Native MediaElement -->
            <MediaElement x:Name="PlayerMediaElement"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          Visibility="Collapsed" />

            <!-- WebView2 Web Player -->
            <wv2:WebView2 x:Name="PlayerWebView"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Visibility="Collapsed" />

            <!-- Airspace-safe Popup Overlay for HwndHost -->
            <Popup x:Name="PlayerOverlayPopup"
                   PlacementTarget="{Binding ElementName=VideoView}"
                   Placement="Center"
                   AllowsTransparency="True"
                   Width="{Binding ActualWidth, ElementName=VideoView}"
                   Height="{Binding ActualHeight, ElementName=VideoView}">
                
                <!-- Overlay Background -->
                <Grid Background="#01000000"
                      PreviewMouseMove="Player_MouseMove"
                      MouseLeftButtonDown="Player_MouseLeftButtonDown">

                    <!-- Buffering -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#99000000" CornerRadius="12" Padding="24,16"
                            Visibility="{Binding PlayerVm.IsBuffering,
                                         Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconBuffer}" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding PlayerVm.StatusText}"
                                       Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Error -->
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="#99200000" CornerRadius="12" Padding="24,16"
                            Visibility="{Binding PlayerVm.ErrorText,
                                         Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                <Path Data="{StaticResource IconWarning}" Stroke="{StaticResource ErrorRed}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Playback Error" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ErrorRed}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding PlayerVm.ErrorText}"
                                       Foreground="#FFDDDD" FontSize="13"
                                       TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- TOP BAR -->
                    <Border x:Name="PlayerTopBar"
                            VerticalAlignment="Top" HorizontalAlignment="Stretch"
                            Opacity="0" IsHitTestVisible="False"
                            MouseEnter="PlayerBar_MouseEnter" MouseLeave="PlayerBar_MouseLeave"
                            Padding="12,10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#CC000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Back to browse -->
                            <Button Grid.Column="0" Style="{StaticResource CtrlBtn}"
                                    Click="BackToLibrary_Click" ToolTip="Back to library">
                                <Path Data="{StaticResource IconBack}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                            </Button>

                            <!-- Channel info -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="12,0">
                                <Image Source="{Binding PlayerVm.StreamIconUrl}"
                                       Width="26" Height="26"
                                       RenderOptions.BitmapScalingMode="LowQuality"
                                       Margin="0,0,8,0">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="Source" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Text="{Binding PlayerVm.StreamTitle}"
                                           Foreground="White" FontSize="15" FontWeight="SemiBold"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Fullscreen -->
                            <Button Grid.Column="2" Style="{StaticResource CtrlBtn}"
                                    Command="{Binding PlayerVm.ToggleFullscreenCommand}"
                                    ToolTip="Toggle fullscreen (F)">
                                <Path Data="{StaticResource IconFullscreen}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- BOTTOM BAR -->
                    <Border x:Name="PlayerBottomBar"
                            VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                            Opacity="0" IsHitTestVisible="False"
                            MouseEnter="PlayerBar_MouseEnter" MouseLeave="PlayerBar_MouseLeave"
                            Padding="16,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Seekbar -->
                            <Grid Grid.Row="0" Margin="0,0,0,10"
                                  Visibility="{Binding PlayerVm.IsSeekable,
                                               Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding PlayerVm.PositionText}"
                                           Foreground="White" FontSize="12" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1"
                                        Minimum="0" Maximum="1" Value="{Binding PlayerVm.Position, Mode=OneWay}"
                                        SmallChange="0.001" LargeChange="0.05"
                                        IsMoveToPointEnabled="True"
                                        Thumb.DragStarted="SeekSlider_DragStarted"
                                        Thumb.DragCompleted="SeekSlider_DragCompleted"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource AccentBlue}"/>
                                <TextBlock Grid.Column="2" Text="{Binding PlayerVm.LengthText}"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Controls -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.SkipBackwardCommand}"
                                            Margin="0,0,4,0" ToolTip="Skip Backward 5s (Left Arrow)">
                                        <Path Data="{StaticResource IconSkipBack}" Style="{StaticResource VectorIcon}" Width="12" Height="12"/>
                                    </Button>
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.TogglePlayCommand}"
                                            Margin="0,0,4,0" ToolTip="Play / Pause (Space)">
                                        <Path Width="14" Height="14">
                                            <Path.Style>
                                                <Style TargetType="Path" BasedOn="{StaticResource VectorIconFilled}">
                                                    <Setter Property="Data" Value="{StaticResource IconPlay}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlayerVm.IsPlaying}" Value="True">
                                                            <Setter Property="Data" Value="{StaticResource IconPause}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Button>
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.SkipForwardCommand}"
                                            Margin="0,0,8,0" ToolTip="Skip Forward 5s (Right Arrow)">
                                        <Path Data="{StaticResource IconSkipForward}" Style="{StaticResource VectorIcon}" Width="12" Height="12"/>
                                    </Button>
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.PlayNextEpisodeCommand}"
                                            Visibility="{Binding PlayerVm.HasNextEpisode, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Margin="0,0,8,0" ToolTip="Next Episode (N)">
                                        <Path Data="{StaticResource IconNextEpisode}" Style="{StaticResource VectorIcon}" Width="12" Height="12"/>
                                    </Button>
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.StopCommand}"
                                            Margin="0,0,14,0" ToolTip="Stop">
                                        <Path Data="{StaticResource IconStop}" Style="{StaticResource VectorIconFilled}" Width="12" Height="12"/>
                                    </Button>
                                    <TextBlock Text="{Binding PlayerVm.StatusText}"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="12" VerticalAlignment="Center"
                                               Visibility="{Binding PlayerVm.StatusText,
                                                            Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                </StackPanel>

                                <!-- Right -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    
                                    <!-- Settings -->
                                    <Border Background="{DynamicResource InputBg}" 
                                            BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                            CornerRadius="6" Padding="8,4" Margin="0,0,14,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="SPEED:" Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox Width="58" Style="{StaticResource PlayerComboBoxStyle}" Margin="0,0,8,0"
                                                      ItemsSource="{Binding PlayerVm.PlaybackSpeeds}"
                                                      SelectedItem="{Binding PlayerVm.SelectedSpeed, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat='{}{0}x'}" Foreground="White" FontSize="11"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            
                                            <TextBlock Text="DUB:" Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox Width="95" Style="{StaticResource PlayerComboBoxStyle}" Margin="0,0,8,0"
                                                      ItemsSource="{Binding PlayerVm.AudioStreams}"
                                                      SelectedItem="{Binding PlayerVm.SelectedAudioStream, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Foreground="White" FontSize="11" TextTrimming="CharacterEllipsis">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0} ({1})">
                                                                    <Binding Path="Language" />
                                                                    <Binding Path="Codec" />
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                             <TextBlock Text="SUB:" Foreground="{DynamicResource TextMuted}"
                                                        FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                             <ComboBox Width="95" Style="{StaticResource PlayerComboBoxStyle}"
                                                       ItemsSource="{Binding PlayerVm.DisplaySubtitleStreams}"
                                                       SelectedValuePath="Value"
                                                       SelectedValue="{Binding PlayerVm.SelectedSubtitleStream, Mode=TwoWay}">
                                                 <ComboBox.ItemTemplate>
                                                     <DataTemplate>
                                                         <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                     </DataTemplate>
                                                 </ComboBox.ItemTemplate>
                                             </ComboBox>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Button Style="{StaticResource CtrlBtn}"
                                            Command="{Binding PlayerVm.ToggleMuteCommand}"
                                            Margin="0,0,8,0" ToolTip="Toggle mute (M)">
                                        <Path Width="14" Height="14">
                                            <Path.Style>
                                                <Style TargetType="Path" BasedOn="{StaticResource VectorIcon}">
                                                    <Setter Property="Data" Value="{StaticResource IconUnmute}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PlayerVm.IsMuted}" Value="True">
                                                            <Setter Property="Data" Value="{StaticResource IconMute}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Button>
                                    <Slider Minimum="0" Maximum="100"
                                            Value="{Binding PlayerVm.Volume}"
                                            Width="80" VerticalAlignment="Center"
                                            Foreground="{DynamicResource AccentBlue}"
                                            IsMoveToPointEnabled="True"
                                            ToolTip="Volume"/>
                                    <TextBlock Text="{Binding PlayerVm.Volume, StringFormat='{}{0}%'}"
                                               Foreground="{DynamicResource TextMuted}"
                                               Margin="5,0,0,0" VerticalAlignment="Center" Width="36"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Popup>
        </Grid>
        <!-- end PlayerPanel -->

    
        <!-- ══════════ SETTINGS MODAL OVERLAY ═══════════════════════════════════ -->
        <Grid x:Name="SettingsModalOverlay"
              Background="#99000000"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Panel.ZIndex="100"
              MouseLeftButtonDown="SettingsOverlay_MouseLeftButtonDown">
            
            <!-- Centered Glassy Card -->
            <Border Width="850" Height="600"
                    Background="{DynamicResource BgDeep}"
                    BorderBrush="{DynamicResource DividerColor}"
                    BorderThickness="1"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.5" ShadowDepth="0"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Content -->
                    </Grid.RowDefinitions>

                    <!-- Header Banner -->
                    <Border Grid.Row="0" Padding="24,18" Background="{DynamicResource BgSidebar}"
                            BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1"
                            CornerRadius="16,16,0,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="SETTINGS" Foreground="{DynamicResource AccentBlue}" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="Configure your accounts and application preferences" Foreground="{DynamicResource TextPrimary}" FontSize="18" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Close Button (✕) -->
                            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Command="{Binding CloseSettingsCommand}"
                                    Cursor="Hand" Width="32" Height="32" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" CornerRadius="16" Background="Transparent">
                                                        <TextBlock Text="✕" FontFamily="Segoe UI" FontSize="16" Foreground="{DynamicResource TextMuted}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/> <!-- Accounts -->
                            <ColumnDefinition Width="30"/> <!-- Spacer -->
                            <ColumnDefinition Width="*"/> <!-- General settings -->
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: IPTV Accounts -->
                        <StackPanel Grid.Column="0">
                            <!-- Section Title -->
                            <TextBlock Text="IPTV Accounts" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

                            <!-- List of Accounts -->
                            <ListBox ItemsSource="{Binding SavedAccounts}"
                                     Background="Transparent" BorderThickness="0"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     Margin="0,0,0,16">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource DividerColor}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Account Details -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Username}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                                        <!-- Default Account Badge -->
                                                        <Border Background="#2E7D32" CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                                Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBlock Text="DEFAULT" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding BaseUrl}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,4,0,0"/>
                                                </StackPanel>

                                                <!-- Account Actions -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <!-- Make Default Button -->
                                                    <Button Content="Set Default"
                                                            Command="{Binding DataContext.SetDefaultAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Cursor="Hand" Height="32" Padding="12,0" Margin="0,0,8,0">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#1A4F8EF7"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>

                                                    <!-- Delete Button -->
                                                    <Button Command="{Binding DataContext.RemoveAccountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Cursor="Hand" Width="32" Height="32">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                                <TextBlock Text="🗑" Foreground="{StaticResource ErrorRed}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#33FF5370"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Add New Account Info -->
                            <Border Background="#1A4F8EF7" BorderBrush="#334F8EF7" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Want to add another service?" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Click Logout in the sidebar to return to the sign-in screen, enter the credentials, and ensure 'Remember Me' is checked."
                                               Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0" LineHeight="16"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- RIGHT: General preferences -->
                        <StackPanel Grid.Column="2">
                            <!-- Section Title -->
                            <TextBlock Text="General Preferences" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

                            <!-- Preferences Card -->
                            <Border Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource DividerColor}" BorderThickness="1" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <!-- Auto-Login Option -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Automatic Sign-In" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="Bypasses the login screen and automatically connects to your default IPTV service at startup."
                                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding AutoLogin}" Style="{DynamicResource ToggleCheckBoxStyle}"/>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,20"/>

                                    <!-- Downloads Folder Preference -->
                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="Downloads Directory" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Select the local directory where your downloaded movies and shows will be saved."
                                                   Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" Height="38" Text="{Binding DownloadFolder}" IsReadOnly="True"/>
                                            <Button Grid.Column="1" Content="Browse..." Command="{Binding ChangeDownloadFolderCommand}" Height="38" Padding="16,0" Margin="8,0,0,0" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,20"/>

                                    <!-- Max Concurrent Downloads Preference -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Maximum Active Downloads" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="Limit the number of files downloaded in parallel. Additional downloads will be queued."
                                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1" VerticalAlignment="Center" Height="36" Style="{StaticResource SettingsComboBoxStyle}" SelectedItem="{Binding MaxConcurrentDownloads}">
                                            <ComboBox.Items>
                                                <sys:Int32>1</sys:Int32>
                                                <sys:Int32>2</sys:Int32>
                                                <sys:Int32>3</sys:Int32>
                                                <sys:Int32>4</sys:Int32>
                                                <sys:Int32>5</sys:Int32>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,20"/>

                                    <!-- Default Video format Preference -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Fallback Video Format" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="The file format/extension requested from the server when streaming or downloading."
                                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1" VerticalAlignment="Center" Height="36" Style="{StaticResource SettingsComboBoxStyle}" SelectedItem="{Binding DefaultContainerExtension}">
                                            <ComboBox.Items>
                                                <sys:String>ts</sys:String>
                                                <sys:String>mp4</sys:String>
                                                <sys:String>mkv</sys:String>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,20,0,20"/>

                                    <!-- Media Player Engine Preference -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Media Player Engine" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="Choose which playback engine/method to use for streaming content."
                                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1" VerticalAlignment="Center" Height="36" Style="{StaticResource SettingsComboBoxStyle}" SelectedItem="{Binding SelectedPlayerEngine}">
                                            <ComboBox.Items>
                                                <sys:String>Flyleaf</sys:String>
                                                <sys:String>VLC</sys:String>
                                                <sys:String>MediaElement</sys:String>
                                                <sys:String>WebView2</sys:String>
                                                <sys:String>MPV</sys:String>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,20,0,20"/>

                                    <!-- Application Theme Preference -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Application Theme" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="Customize the interface color scheme and branding theme."
                                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <ComboBox Grid.Column="1" VerticalAlignment="Center" Height="36" Style="{StaticResource SettingsComboBoxStyle}" SelectedItem="{Binding SelectedTheme}">
                                            <ComboBox.Items>
                                                <sys:String>Dark Purple</sys:String>
                                                <sys:String>Midnight Black</sys:String>
                                                <sys:String>Cyberpunk Neon</sys:String>
                                                <sys:String>Forest Green</sys:String>
                                                <sys:String>Light Ocean</sys:String>
                                            </ComboBox.Items>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Save / Apply Settings Button -->
                            <Button Content="Save Settings"
                                    Command="{Binding ApplyGeneralSettingsCommand}"
                                    Cursor="Hand" Height="44" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,16,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" CornerRadius="8">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#4F8EF7" Offset="0"/>
                                                                <GradientStop Color="#7C5CBF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
</Grid>
</Window>
