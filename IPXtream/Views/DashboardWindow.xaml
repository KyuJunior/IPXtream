<Window x:Class="IPXtream.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:fl="clr-namespace:FlyleafLib.Controls.WPF;assembly=FlyleafLib"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="IPXtream"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <sys:Int32 x:Key="Limit0">0</sys:Int32>
        <sys:Int32 x:Key="Limit256">256</sys:Int32>
        <sys:Int32 x:Key="Limit512">512</sys:Int32>
        <sys:Int32 x:Key="Limit1024">1024</sys:Int32>
        <sys:Int32 x:Key="Limit2048">2048</sys:Int32>
        <sys:Int32 x:Key="Limit5120">5120</sys:Int32>
        <sys:Int32 x:Key="Limit10240">10240</sys:Int32>
        <SolidColorBrush x:Key="BgDeep"       Color="#E006060D"/>
        <SolidColorBrush x:Key="BgSidebar"    Color="#AA0E0E1B"/>
        <SolidColorBrush x:Key="BgCard"       Color="#BC141424"/>
        <SolidColorBrush x:Key="BgHover"      Color="#1E1E38"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#5B9BFF"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8B6BD4"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#F0F0F8"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#7A7A90"/>
        <SolidColorBrush x:Key="InputBg"      Color="#CC0E0E20"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#30FFFFFF"/>
        <SolidColorBrush x:Key="DividerColor" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ErrorRed"     Color="#FF5370"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#00E676"/>

        <!-- Section Transition Storyboard -->
        <Storyboard x:Key="SectionTransitionStoryboard">
            <DoubleAnimation Storyboard.TargetName="ContentAreaPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentAreaTranslate"
                             Storyboard.TargetProperty="Y"
                             From="15" To="0" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <CollectionViewSource x:Key="GroupedDownloads" Source="{Binding Downloads}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <!-- ── Category list item ──────────────────────────────────────────── -->
        <Style x:Key="CategoryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="14" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryAccentGradient}"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" Color="{DynamicResource AccentBlueColor}" Opacity="0.3" ShadowDepth="2" Direction="270"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stream card ────────────────────────────────────────────────── -->
        <Style x:Key="StreamItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin"          Value="5"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="1.5" BorderBrush="Transparent"
                                CornerRadius="12" Margin="{TemplateBinding Margin}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Color="#000000" Opacity="0.3" ShadowDepth="2" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="20" Color="{DynamicResource AccentBlueColor}" Opacity="0.45" ShadowDepth="4" Direction="270"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.04" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.04" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Horizontal ListBox Style ── -->
        <Style x:Key="HorizontalListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="OpacityMask">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="Black" Offset="0.02"/>
                        <GradientStop Color="Black" Offset="0.96"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <EventSetter Event="PreviewMouseWheel" Handler="HorizontalListBox_PreviewMouseWheel"/>
        </Style>



        <!-- ── Search TextBox ──────────────────────────────────────────────── -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="32,0,12,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBlue}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="OuterBd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="19">
                            <Grid>
                                <!-- Search icon -->
                                <Path Data="{StaticResource IconSearch}" 
                                      Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" 
                                      Width="14" Height="14" Stretch="Uniform"
                                      HorizontalAlignment="Left" VerticalAlignment="Center"
                                      Margin="12,0,0,0" IsHitTestVisible="False"/>
                                <TextBlock Text="Search channels, movies, and series..." 
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Opacity="0.5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Focusable="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="OuterBd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" Color="{DynamicResource AccentBlueColor}" Opacity="0.25" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Settings TextBox Style ──────────────────────────────────────── -->
        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBlue}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource AccentBlue}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <!-- Placeholder text using Tag -->
                                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Opacity="0.5">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              Focusable="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" Color="{DynamicResource AccentBlueColor}" Opacity="0.25" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Play button ────────────────────────────────────────────────── -->
        <Style x:Key="PlayBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Background="{DynamicResource PrimaryAccentGradient}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Player control button ──────────────────────────────────────── -->
        <Style x:Key="CtrlBtn" TargetType="Button">
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="20" Background="#44FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#77FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#99FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stream Card DataTemplate ────────────────────────────────────── -->
        <DataTemplate x:Key="StreamCardTemplate">
            <Border Width="135" Height="240" CornerRadius="12" Background="{DynamicResource BgSidebar}" 
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <!-- Poster -->
                    <Image Source="{Binding StreamIcon, Converter={StaticResource CachedImageConverter}}"
                           Stretch="UniformToFill">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Style.Triggers>
                                    <Trigger Property="Source" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    
                    <!-- Fallback empty state icon -->
                    <Path Data="{StaticResource IconTv}" Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="40" Height="40" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path.Style>
                            <Style TargetType="Path">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StreamIcon}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StreamIcon}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>

                    <!-- Translucent Glass Info Panel -->
                    <Border VerticalAlignment="Bottom" Height="65" Background="#C50E0E1B" BorderThickness="0,1,0,0" BorderBrush="#15FFFFFF">
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="36"
                                       Margin="8,0,8,0" HorizontalAlignment="Center" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Hover Overlay with Buttons -->
                    <Border x:Name="HoverOverlay" Background="#B0000000" Opacity="0">
                        <UniformGrid x:Name="HoverGrid" Columns="2" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <UniformGrid.RenderTransform>
                                <TranslateTransform x:Name="HoverGridTranslate" X="0" Y="20"/>
                            </UniformGrid.RenderTransform>
                            <!-- Play -->
                            <Button Margin="6" Width="44" Height="44" Padding="0" FontSize="18" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                    Command="{Binding DataContext.PlayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PlayBd" CornerRadius="22">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Path Data="{StaticResource IconPlay}" Style="{StaticResource VectorIconFilled}" Width="16" Height="16" Margin="2,0,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PlayBd" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- Download -->
                            <Button Margin="6" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding IsDownloadable, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.DownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Download to ~/Downloads/IPXtream/&#x0a;(Includes all embedded subtitles automatically)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DlBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path Data="{StaticResource IconDownloads}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DlBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- About Movie Info Button -->
                            <Button Margin="6" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding IsMovie, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ShowMovieInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="About Movie">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="InfoBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path Data="{StaticResource IconInfo}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="InfoBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Toggle Like (Heart Button) -->
                            <Button Margin="6" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Command="{Binding DataContext.ToggleLikeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Like / Unlike">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="LikeBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path x:Name="LikePath" Data="{StaticResource IconHeart}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="LikeBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                                <Setter TargetName="LikePath" Property="Fill" Value="#FF4A5A"/>
                                                <Setter TargetName="LikePath" Property="Stroke" Value="#FF4A5A"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Toggle Watch Later (Clock Button) -->
                            <Button Margin="6" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding IsDownloadable, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ToggleWatchLaterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Watch Later">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="WLBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path x:Name="WLPath" Data="{StaticResource IconClock}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="WLBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsWatchLater}" Value="True">
                                                <Setter TargetName="WLPath" Property="Fill" Value="#FFD700"/>
                                                <Setter TargetName="WLPath" Property="Stroke" Value="#FFD700"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Toggle Featured (Star Button) -->
                            <Button Margin="6" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ToggleFeaturedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Add / Remove from What's new?">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="StarBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path x:Name="StarPath" Data="{StaticResource IconStar}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="StarBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsFeatured}" Value="True">
                                                <Setter TargetName="StarPath" Property="Fill" Value="#FFD700"/>
                                                <Setter TargetName="StarPath" Property="Stroke" Value="#FFD700"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Toggle Dev Recommendation (Heart Button) -->
                            <Button Margin="6" Width="44" Height="44" FontSize="18" Cursor="Hand" Background="#44FFFFFF" BorderThickness="0"
                                    Visibility="{Binding DataContext.IsAdminMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.ToggleDevRecommendationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Mark / Unmark as Dev Recommendation">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="HeartBd" CornerRadius="22" Background="{TemplateBinding Background}">
                                            <Path x:Name="HeartPath" Data="{StaticResource IconHeart}" Style="{StaticResource VectorIcon}" Width="16" Height="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeartBd" Property="Background" Value="#66FFFFFF"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsDevRecommendation}" Value="True">
                                                <Setter TargetName="HeartPath" Property="Fill" Value="#FF4A5A"/>
                                                <Setter TargetName="HeartPath" Property="Stroke" Value="#FF4A5A"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </UniformGrid>
                    </Border>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25"/>
                                <DoubleAnimation Storyboard.TargetName="HoverGridTranslate" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="HoverGridTranslate" Storyboard.TargetProperty="Y" To="20" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ── ComboBox item style for Settings ──────────────────────────── -->
        <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox style for Settings ───────────────────────────────── -->
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Background="{TemplateBinding Background}"
                                          Grid.Column="2"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Grid HorizontalAlignment="Right" Width="30">
                                                <Path x:Name="Arrow"
                                                      Fill="{DynamicResource TextMuted}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,30,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource InputBg}"
                                            BorderBrush="{DynamicResource InputBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,2,0,0">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox item style for Player Controls ───────────────────── -->
        <Style x:Key="PlayerComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ComboBox style for Player Controls ────────────────────────── -->
        <Style x:Key="PlayerComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource PlayerComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Background="{TemplateBinding Background}"
                                          Grid.Column="2"
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid HorizontalAlignment="Right" Width="18">
                                                <Path x:Name="Arrow"
                                                      Fill="{DynamicResource TextMuted}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 3.5 3.5 L 7 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,0,18,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource InputBg}"
                                            BorderBrush="{DynamicResource InputBorder}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,2,0,0">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="50"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle Switch style for CheckBox ────────────────────────────── -->
        <Style x:Key="ToggleCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Track"
                                    Width="44" Height="22"
                                    CornerRadius="11"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource InputBorder}"
                                    BorderThickness="1">
                                <Ellipse x:Name="Thumb"
                                         Width="16" Height="16"
                                         Fill="#888899"
                                         HorizontalAlignment="Left"
                                         Margin="2,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Global ScrollBar Style is loaded from App.xaml -->

        <!-- ── Custom Premium Slider Style ── -->
        <Style x:Key="PremiumSliderStyle" TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Background" Value="#25FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid x:Name="GridRoot">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Track Background -->
                            <Border x:Name="TrackBackground" Grid.Row="1" Height="4" CornerRadius="2" Background="{TemplateBinding Background}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Background="{TemplateBinding Foreground}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2,0,0,2" Background="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="12" Height="12" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="6" Background="White" Width="12" Height="12" BorderBrush="{DynamicResource AccentBlue}" BorderThickness="1.5">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="4" Color="Black" Opacity="0.3" ShadowDepth="1"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackBackground" Property="Height" Value="6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── NavBtn & NavBtnActive Horizontal Pill Overrides ── -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                               HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DividerColor}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#25FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#405B9BFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#255B9BFF" Offset="0"/>
                        <GradientStop Color="#258B6BD4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                               HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#355B9BFF" Offset="0"/>
                                            <GradientStop Color="#358B6BD4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#605B9BFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Geometry x:Key="IconUser">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</Geometry>

    </Window.Resources>

    <!-- ── Window load animation ──────────────────────────────────────────────── -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.35"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!--
        Root Grid has two layers:
          [0] Dashboard content (sidebar + categories + streams)
          [1] Player panel — hidden by default, slides over the content area (columns 1+2)
              when a stream is playing. Sidebar stays visible.
    -->
    <Grid Background="{DynamicResource BgDeep}">
        <!-- Ambient Backdrop Artwork Glow (Apple TV+ style) -->
        <Grid IsHitTestVisible="False">
            <!-- Static geometric backdrop -->
            <Image Source="/dashboard_bg.png" Stretch="UniformToFill" Opacity="0.45"/>
            <!-- Dynamic ambient cover glow -->
            <Image Source="{Binding FeaturedCarouselItem.Cover}" Stretch="UniformToFill" Opacity="0.08" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image.Effect>
                    <BlurEffect Radius="100" RenderingBias="Quality"/>
                </Image.Effect>
            </Image>
            <!-- Overlay to blend the glow into the deep background -->
            <Border Background="{DynamicResource BgDeep}"/>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             LAYER 0 — DASHBOARD
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid x:Name="DashboardGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/> <!-- Row 0: Top Bar -->
                <RowDefinition Height="*"/>  <!-- Row 1: Main Content -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- Categories column (collapsible) -->
                <ColumnDefinition x:Name="CategoriesCol" Width="230"/>
                <!-- Streams column -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════ TOP NAVIGATION BAR ══════════════════════════════ -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource BgDeep}" BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,0,1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.3" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Logo -->
                        <ColumnDefinition Width="*"/>    <!-- Navigation pills -->
                        <ColumnDefinition Width="Auto"/> <!-- Right Actions / Profile -->
                    </Grid.ColumnDefinitions>

                    <!-- Branding Logo (Left) -->
                    <Border Grid.Column="0" Margin="24,0,24,0" VerticalAlignment="Center" CornerRadius="12" Padding="14,6" Background="{DynamicResource BgCard}" BorderBrush="{DynamicResource DividerColor}" BorderThickness="1" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding SelectSectionCommand}" CommandParameter="home"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal">
                            <!-- Play icon in a dark rounded square -->
                            <Border Width="22" Height="22" CornerRadius="5" Margin="0,0,8,0" Background="{DynamicResource PrimaryAccentGradient}">
                                <Path Data="{StaticResource IconLogo}" Fill="White" Stretch="Uniform" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="IPXtream" FontSize="14" FontWeight="Black" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Navigation Pills (Center) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- Cache / Cancel toggle -->
                        <Button Command="{Binding CancelCacheCommand}"
                                Visibility="{Binding IsCachingAll, Converter={StaticResource BoolToVisibilityConverter}}"
                                Style="{StaticResource NavBtn}" Padding="10,6" ToolTip="Cancel Caching">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCancel}" Style="{StaticResource VectorIcon}" Width="14" Height="14" Margin="0,0,6,0" Stroke="Red"/>
                                <TextBlock Text="Cancel Cache" FontSize="11" Foreground="Red" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CacheAllBackgroundCommand}"
                                Visibility="{Binding IsCachingAll, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Style="{StaticResource NavBtn}" Padding="10,6" ToolTip="Cache Entire Library">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCloud}" Style="{StaticResource VectorIcon}" Width="14" Height="14" Margin="0,0,6,0" Stroke="{StaticResource AccentBlue}"/>
                                <TextBlock Text="Cache All" FontSize="11" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Refresh Button -->
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource NavBtn}" Padding="8" ToolTip="Refresh Current View" Margin="4,0">
                            <Path Data="{StaticResource IconRefresh}" Style="{StaticResource VectorIcon}" Width="14" Height="14"/>
                        </Button>

                        <!-- Settings Button -->
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="settings" Style="{StaticResource NavBtn}" Padding="8" ToolTip="Settings" Margin="4,0">
                            <Path Data="{StaticResource IconSettings}" Style="{StaticResource VectorIcon}" Width="14" Height="14"/>
                        </Button>

                        <!-- Switch Account Button -->
                        <Button Command="{Binding OpenSwitchAccountCommand}" Style="{StaticResource NavBtn}" Padding="8" ToolTip="Switch Account" Margin="4,0">
                            <Path Data="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8 M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75" 
                                  Style="{StaticResource VectorIcon}" Width="14" Height="14"/>
                        </Button>

                        <!-- Logout Button -->
                        <Button Command="{Binding LogoutCommand}" Style="{StaticResource NavBtn}" Padding="8" ToolTip="Logout" Margin="4,0">
                            <Path Data="{StaticResource IconLogout}" Style="{StaticResource VectorIcon}" Width="14" Height="14" Stroke="{StaticResource ErrorRed}"/>
                        </Button>
                    </StackPanel>

                    <!-- Right Actions / Profile (Right) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,24,0" VerticalAlignment="Center">

                        <!-- User Profile Card (includes Username, Server, Version, and Update action) -->
                        <Grid Margin="0,0,8,0">
                            <!-- User Card Border -->
                            <Border CornerRadius="12" Padding="14,8" BorderBrush="#20FFFFFF" BorderThickness="1" Background="#AA141422">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.4" ShadowDepth="0"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Avatar -->
                                        <ColumnDefinition Width="Auto"/> <!-- User info -->
                                        <ColumnDefinition Width="16"/>   <!-- Spacer -->
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="UpdateGroup"/> <!-- Version / Update status -->
                                    </Grid.ColumnDefinitions>

                                    <!-- User Avatar (Circle with purple-pink gradient) -->
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#C56BFF" Offset="0"/>
                                                <GradientStop Color="#FF6B9E" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="YS" Foreground="White" FontSize="11" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- User info (Username & Server) -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayUsername}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ServerDisplay}" Foreground="{DynamicResource TextMuted}" FontSize="9"/>
                                    </StackPanel>

                                    <!-- Version / Update info (Right-aligned inside card) -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource TextMuted}" FontSize="8" HorizontalAlignment="Right" FontWeight="Bold" Cursor="Hand" MouseDown="Version_MouseDown" ToolTip="Click to view release details"/>
                                        
                                        <!-- Update status TextBlock -->
                                        <TextBlock Text="{Binding UpdateStatus}" Foreground="{DynamicResource TextMuted}" FontSize="9" HorizontalAlignment="Right" Margin="0,1,0,0"
                                                   Visibility="{Binding UpdateStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>

                                        <!-- Check for updates button -->
                                        <Button Command="{Binding CheckForUpdatesCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" HorizontalAlignment="Right" Margin="0,1,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDownloadingUpdate}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding UpdateUrl, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="Check updates" FontSize="9" Foreground="{DynamicResource AccentBlue}" TextDecorations="Underline"/>
                                        </Button>

                                        <!-- Clickable "download update" link -->
                                        <Button Command="{Binding DownloadAndInstallUpdateCommand}"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="0" HorizontalAlignment="Right" Margin="0,1,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding UpdateUrl, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible"/>
                                                                <Condition Binding="{Binding IsDownloadingUpdate}" Value="False"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="Download Update" FontSize="9" Foreground="#FF9E80" TextDecorations="Underline" FontWeight="Bold"/>
                                        </Button>

                                        <!-- In-app Download Progress Panel -->
                                        <StackPanel Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibilityConverter}}" Width="70" Margin="0,2,0,0">
                                            <ProgressBar Height="3" Minimum="0" Maximum="1"
                                                         Value="{Binding UpdateDownloadProgress, Mode=OneWay}"
                                                         Background="#1F1F3D" Foreground="{DynamicResource AccentBlue}"
                                                         BorderThickness="0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Red notification dot badge in top-right corner -->
                            <Border Width="8" Height="8" CornerRadius="4" Background="#FF3B30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-2,-2,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateUrl, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════ UNIFIED SIDEBAR ══════════════════════════════════ -->
            <Border x:Name="SidebarPanel" Grid.Row="1" Grid.Column="0" Background="{DynamicResource BgDeep}"
                    BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Navigation Section -->
                        <RowDefinition Height="Auto"/> <!-- Divider -->
                        <RowDefinition Height="*"/>    <!-- Category List (when active) -->
                    </Grid.RowDefinitions>

                    <!-- Sidebar Navigation (Home, WhatsNew, CurrentlyWatching) -->
                    <StackPanel Grid.Row="0" Margin="12,16,12,12">
                        <!-- Navigation Item Style / ListBox could be used, or just buttons -->
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="home"
                                Style="{Binding ActiveSection, Converter={StaticResource SectionToStyleConverter}, ConverterParameter=Home}"
                                Height="40" Margin="0,0,0,6"
                                HorizontalContentAlignment="Left" Padding="12,0">
                            <!-- Background color change if active -->
                            <Button.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSection}" Value="Home">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <!-- Home Icon -->
                                <Path Data="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" Style="{StaticResource VectorIcon}" Width="14" Height="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Home" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="whatsnew"
                                Style="{Binding ActiveSection, Converter={StaticResource SectionToStyleConverter}, ConverterParameter=WhatsNew}"
                                Height="40" Margin="0,0,0,6"
                                HorizontalContentAlignment="Left" Padding="12,0">
                            <Button.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <!-- Sparkles/Flame Icon -->
                                <Path Data="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" Style="{StaticResource VectorIcon}" Width="14" Height="14" Margin="0,0,10,0"/>
                                <TextBlock Text="What's New" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="currentlywatching"
                                Style="{Binding ActiveSection, Converter={StaticResource SectionToStyleConverter}, ConverterParameter=CurrentlyWatching}"
                                Height="40" Margin="0,0,0,6"
                                HorizontalContentAlignment="Left" Padding="12,0">
                            <Button.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSection}" Value="CurrentlyWatching">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                            <StackPanel Orientation="Horizontal">
                                <!-- Library Icon -->
                                <Path Data="M4 19.5A2.5 2.5 0 0 1 6.5 17H20 M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5z" Style="{StaticResource VectorIcon}" Width="14" Height="14" Margin="0,0,10,0"/>
                                <TextBlock Text="My Library" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="downloads"
                                Style="{Binding ActiveSection, Converter={StaticResource SectionToStyleConverter}, ConverterParameter=Downloads}"
                                Height="40" Margin="0,0,0,6"
                                HorizontalContentAlignment="Left" Padding="12,0">
                            <Button.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Resources>
                            <Grid HorizontalAlignment="Stretch" Width="180">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <!-- Downloads Icon -->
                                    <Path Data="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M7 10l5 5 5-5 M12 15V3" Style="{StaticResource VectorIcon}" Width="14" Height="14" Margin="0,0,10,0"/>
                                    <TextBlock Text="Downloads" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Active download count badge -->
                                <Border Grid.Column="2" Background="{DynamicResource AccentBlue}" CornerRadius="8"
                                        Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding HasActiveDownloads,
                                                     Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ActiveDownloadCount}"
                                               FontSize="10" Foreground="White"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerColor}" Margin="12,0,12,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="CurrentlyWatching">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Settings">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Home">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Category Panel Content (Visible only for LiveTV, VOD, Series) -->
                    <Grid Grid.Row="2">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="WhatsNew">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="CurrentlyWatching">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Settings">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="Home">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="16,0,16,12">
                                <StackPanel>
                                    <TextBlock Text="CATEGORIES"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Text="Loading…"
                                               Foreground="{DynamicResource AccentBlue}"
                                               FontSize="12" Margin="0,4,0,0"
                                               Visibility="{Binding IsLoadingCategories,
                                                             Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding Categories}"
                                     SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                     ItemContainerStyle="{StaticResource CategoryItemStyle}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding CategoryName}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Error + Retry -->
                            <Border Grid.Row="1" VerticalAlignment="Top"
                                    Background="#441A0A" CornerRadius="8"
                                    Padding="10,8" Margin="8,4"
                                    Visibility="{Binding ErrorMessage,
                                                 Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               Foreground="#FF7B6B" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,0,0,6"/>
                                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="live"
                                            Background="{DynamicResource AccentBlue}" Foreground="White"
                                            BorderThickness="0" Padding="8,4"
                                            FontSize="11" FontWeight="Bold" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        &#x21BA; Retry
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ══════════ CONTENT AREA PANEL ════════════════════════════════ -->
            <Grid x:Name="ContentAreaPanel" Grid.Row="1" Grid.Column="1" Background="Transparent">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ContentAreaTranslate" X="0" Y="0"/>
                </Grid.RenderTransform>

                <!-- ══════════ STREAMS ═══════════════════════════════════════════ -->
                <Grid x:Name="StreamsPanel" Background="Transparent">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="Downloads">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="Settings">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: Toolbar -->
                    <RowDefinition Height="Auto"/>  <!-- 1: Series Details Banner -->
                    <RowDefinition Height="Auto"/>  <!-- 2: Seasons tabs -->
                    <RowDefinition Height="Auto"/>  <!-- 3: Hero Banner -->
                    <RowDefinition Height="*"/>     <!-- 4: Stream card grid -->
                    <RowDefinition Height="Auto"/>  <!-- 5: Status bar -->
                    <RowDefinition Height="Auto"/>  <!-- 6: Downloads tray -->
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="16,12" BorderThickness="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Centered Search Box -->
                        <TextBox x:Name="SearchTextBox" Grid.Column="0" Style="{StaticResource SearchBox}" Height="38" MaxWidth="800"
                                 Foreground="White" HorizontalAlignment="Center" Width="700"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedCategory.CategoryName}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="14" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="16,0,0,0"
                                   Visibility="{Binding HasSelectedCategory,
                                                Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>

                <!-- Error banner -->
                <Border Grid.Row="0" VerticalAlignment="Bottom"
                        Background="#3DFF5370" CornerRadius="8"
                        Padding="12,6" Margin="16,0,16,4"
                        Visibility="{Binding ErrorMessage,
                                     Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorRed}" FontSize="12"/>
                </Border>

                <!-- Series Details Banner -->
                <Border Grid.Row="1" Background="#121225" CornerRadius="10" Margin="16,0,16,10" Padding="16" ClipToBounds="True"
                        Visibility="{Binding IsViewingSeriesInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <!-- Blur Background cover -->
                        <Image Source="{Binding CurrentSeries.Info.Cover}" Stretch="UniformToFill" Opacity="0.15"
                               Width="{Binding ElementName=SeriesDetailsContentGrid, Path=ActualWidth}"
                               Height="{Binding ElementName=SeriesDetailsContentGrid, Path=ActualHeight}">
                            <Image.Effect>
                                <BlurEffect Radius="20"/>
                            </Image.Effect>
                        </Image>

                        <Grid x:Name="SeriesDetailsContentGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Back button and title -->
                                <RowDefinition Height="*"/>    <!-- Content grid (Cover + Info) -->
                            </Grid.RowDefinitions>

                            <!-- Header: Back button + Title -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource NavBtn}"
                                        Command="{Binding BackToSeriesCommand}"
                                        Content="⬅ Back" Padding="12,6" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentSeries.Info.Name}" 
                                           Foreground="White" FontSize="20" FontWeight="Bold" 
                                           VerticalAlignment="Center" Margin="16,0,0,0"/>

                                <!-- Like & Watch Later Action Buttons for Series details -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Like Button -->
                                    <Button Command="{Binding ToggleLikeCommand}" CommandParameter="{Binding SelectedSeriesForInfo}"
                                            Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="14,6" Margin="0,0,8,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="LikeBd" CornerRadius="8" Background="#20FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                        <Path x:Name="LikePath" Data="{StaticResource IconHeart}" Style="{StaticResource VectorIcon}" Width="10" Height="10" Margin="0,0,6,0"/>
                                                        <TextBlock x:Name="LikeText" Text="Like" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="LikeBd" Property="Background" Value="#35FFFFFF"/>
                                                        <Setter TargetName="LikeBd" Property="BorderBrush" Value="#40FFFFFF"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding SelectedSeriesForInfo.IsLiked}" Value="True">
                                                        <Setter TargetName="LikePath" Property="Fill" Value="#FF4A5A"/>
                                                        <Setter TargetName="LikePath" Property="Stroke" Value="#FF4A5A"/>
                                                        <Setter TargetName="LikeText" Property="Text" Value="Liked"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Watch Later Button -->
                                    <Button Command="{Binding ToggleWatchLaterCommand}" CommandParameter="{Binding SelectedSeriesForInfo}"
                                            Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="14,6">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="WLBd" CornerRadius="8" Background="#20FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                                        <Path x:Name="WLPath" Data="{StaticResource IconClock}" Style="{StaticResource VectorIcon}" Width="10" Height="10" Margin="0,0,6,0"/>
                                                        <TextBlock x:Name="WLText" Text="Watch Later" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="WLBd" Property="Background" Value="#35FFFFFF"/>
                                                        <Setter TargetName="WLBd" Property="BorderBrush" Value="#40FFFFFF"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding SelectedSeriesForInfo.IsWatchLater}" Value="True">
                                                        <Setter TargetName="WLPath" Property="Fill" Value="#FFD700"/>
                                                        <Setter TargetName="WLPath" Property="Stroke" Value="#FFD700"/>
                                                        <Setter TargetName="WLText" Property="Text" Value="In Watch Later"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Content Grid -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- Cover image -->
                                    <ColumnDefinition Width="*"/>    <!-- Info text -->
                                </Grid.ColumnDefinitions>

                                <!-- Cover Image -->
                                <Border Grid.Column="0" Width="100" Height="150" CornerRadius="6" ClipToBounds="True"
                                        BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Top">
                                    <Image Source="{Binding CurrentSeries.Info.Cover, Converter={StaticResource CachedImageConverter}}" Stretch="UniformToFill"/>
                                </Border>

                                <!-- Info Text -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <!-- Director / Cast -->
                                    <WrapPanel Margin="0,0,0,8">
                                        <TextBlock Text="Director: " Foreground="{DynamicResource AccentBlue}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentSeries.Info.Director}" Foreground="White" FontSize="12" Margin="0,0,16,0"/>
                                        <TextBlock Text="Cast: " Foreground="{DynamicResource AccentBlue}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CurrentSeries.Info.Cast}" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                                    </WrapPanel>

                                    <!-- Plot -->
                                    <TextBlock Text="Overview" Foreground="{DynamicResource TextMuted}" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CurrentSeries.Info.Plot}" Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap" LineHeight="16"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Seasons Tabs -->
                <Border Grid.Row="2" BorderThickness="0,1,0,1" BorderBrush="#1C1C28" Margin="0,0,0,10"
                        Visibility="{Binding IsViewingSeriesInfo, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListBox ItemsSource="{Binding Seasons}" SelectedItem="{Binding SelectedSeason}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0" Padding="14,0">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="16,10"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border BorderThickness="0,0,0,3" BorderBrush="Transparent" x:Name="Bd" Background="{TemplateBinding Background}">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCard}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- ══════════ HOME HEADER GRID (HERO + CURRENTLY WATCHING) ══════════ -->
                <Grid Grid.Row="3" Margin="16,0,16,14">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowHeroBanner}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6.5*"/> <!-- Left: Hero Banner -->
                        <ColumnDefinition Width="16"/>    <!-- Spacer -->
                        <ColumnDefinition Width="3.5*"/> <!-- Right: Recently Watched -->
                    </Grid.ColumnDefinitions>

                    <!-- Hero Banner -->
                    <Border x:Name="HeroBanner" Grid.Column="0" Height="300" CornerRadius="20" ClipToBounds="True" Background="#C51C1C32" BorderThickness="1.5">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#25FFFFFF" Offset="0"/>
                                <GradientStop Color="#05FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Grid>
                            <!-- Cover Background -->
                            <Image Source="{Binding FeaturedCarouselItem.Cover}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image.Effect>
                                    <BlurEffect Radius="15" RenderingBias="Quality"/>
                                </Image.Effect>
                            </Image>
                            <!-- Gradient Overlay -->
                            <Border>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#250A0A14" Offset="0"/>
                                        <GradientStop Color="#AA0A0A14" Offset="0.6"/>
                                        <GradientStop Color="#F50A0A14" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Details Grid -->
                            <Grid Margin="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Poster -->
                                <Border Grid.Column="0" Width="110" CornerRadius="8" ClipToBounds="True" Background="#0A0A16"
                                        BorderBrush="#25FFFFFF" BorderThickness="1" Margin="0,0,16,0">
                                    <Image Source="{Binding FeaturedCarouselItem.StreamIcon, Converter={StaticResource CachedImageConverter}}" Stretch="UniformToFill"/>
                                </Border>

                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- Tags -->
                                        <RowDefinition Height="Auto"/> <!-- Title -->
                                        <RowDefinition Height="*"/>    <!-- Plot -->
                                        <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                                    </Grid.RowDefinitions>

                                    <!-- Tags -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border CornerRadius="6" Padding="6,2" Margin="0,0,6,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFB800" Offset="0"/>
                                                    <GradientStop Color="#FF8000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="WHAT'S NEW" Foreground="White" FontSize="9" FontWeight="Black"/>
                                        </Border>
                                        <Border Background="{DynamicResource DividerColor}" CornerRadius="6" Padding="6,2" Margin="0,0,6,0">
                                            <TextBlock Text="{Binding FeaturedCarouselItem.ReleaseDate}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="{DynamicResource DividerColor}" CornerRadius="6" Padding="6,2">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconStar}" Fill="#FFD700" Width="8" Height="8" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                                <TextBlock Text="{Binding FeaturedCarouselItem.Rating}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Title -->
                                    <TextBlock Grid.Row="1" Text="{Binding FeaturedCarouselItem.Name}" Foreground="White" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                    <!-- Plot -->
                                    <TextBlock Grid.Row="2" Text="{Binding FeaturedCarouselItem.Plot}" Foreground="{DynamicResource TextMuted}" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" LineHeight="16"/>

                                    <!-- Buttons -->
                                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                                        <Button Command="{Binding PlayCommand}" CommandParameter="{Binding FeaturedCarouselItem}"
                                                Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,8,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="PlayBd" CornerRadius="18" BorderThickness="1" BorderBrush="#33FFFFFF" Padding="22,8" Background="{DynamicResource PrimaryAccentGradient}">
                                                        <StackPanel Orientation="Horizontal">
                                                             <Path Data="M6,4 L18,12 L6,20 Z" Fill="White" Stretch="Uniform" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                             <TextBlock Text="Watch Now" Foreground="White" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="PlayBd" Property="Opacity" Value="0.9"/>
                                                            <Setter TargetName="PlayBd" Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="15" Color="{DynamicResource AccentBlueColor}" Opacity="0.4" ShadowDepth="0"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Button Command="{Binding DownloadCommand}" CommandParameter="{Binding FeaturedCarouselItem}"
                                                Visibility="{Binding FeaturedCarouselItem.IsDownloadable, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Padding="14,6">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="DlBd" CornerRadius="18" Background="#20FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal" Margin="{TemplateBinding Padding}">
                                                            <Path Data="{StaticResource IconDownload}" Style="{StaticResource VectorIconFilled}" Width="10" Height="10" Margin="0,0,6,0"/>
                                                            <TextBlock Text="Download" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="DlBd" Property="Background" Value="#35FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- Carousel Indicators -->
                            <ItemsControl ItemsSource="{Binding FeaturedItems}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectCarouselItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" Margin="3,0" Height="6" Cursor="Hand" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Dot" CornerRadius="2.5" Background="#55FFFFFF" Width="5" Height="5"/>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelectedCarousel}" Value="True">
                                                            <Setter TargetName="Dot" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="Width" To="16" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="Width" To="5" Duration="0:0:0.2">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!-- Currently Watching Panel (right) -->
                    <Border Grid.Column="2" Height="300" CornerRadius="16" Background="#C51C1C32" BorderBrush="#20FFFFFF" BorderThickness="1.5" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Title -->
                                <RowDefinition Height="*"/>    <!-- List -->
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                <Path Data="{StaticResource IconEye}" Stroke="{DynamicResource AccentBlue}" StrokeThickness="2" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="CURRENTLY WATCHING" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Empty state for Currently Watching -->
                            <TextBlock Grid.Row="1" Text="No recently watched items." Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RecentlyWatched.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Horizontal list of recently watched items -->
                            <ListBox Grid.Row="1" ItemsSource="{Binding RecentlyWatched}" SelectedItem="{Binding SelectedStream}"
                                     Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding PlayCommand}" CommandParameter="{Binding SelectedStream}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource StreamItemStyle}">
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource DividerColor}" CornerRadius="12" BorderBrush="{DynamicResource DividerColor}" BorderThickness="1" Padding="10,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="64"/> <!-- Thumbnail -->
                                                    <ColumnDefinition Width="*"/>  <!-- Details -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Thumbnail with Play overlay -->
                                                <Border Grid.Column="0" Height="42" CornerRadius="6" ClipToBounds="True" Background="#0A0A16">
                                                    <Grid>
                                                        <Image Source="{Binding StreamIcon, Converter={StaticResource CachedImageConverter}}" Stretch="UniformToFill"/>
                                                        <Border Background="#40000000">
                                                            <Path Data="{StaticResource IconPlay}" Fill="White" Width="8" Height="8" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- Info -->
                                                <Grid Grid.Column="1" Margin="10,0,0,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/> <!-- Title -->
                                                        <RowDefinition Height="Auto"/> <!-- Progress Text -->
                                                        <RowDefinition Height="Auto"/> <!-- Progress Bar -->
                                                    </Grid.RowDefinitions>

                                                    <!-- Title (Series Name or Stream Name) -->
                                                    <TextBlock Grid.Row="0" Foreground="White" FontSize="12" FontWeight="Bold" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Text>
                                                            <PriorityBinding>
                                                                <Binding Path="SeriesName"/>
                                                                <Binding Path="Name"/>
                                                            </PriorityBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    
                                                    <!-- Subtitle/Progress text -->
                                                    <TextBlock Grid.Row="1" Text="{Binding WatchProgressText}" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,2,0,4"/>

                                                    <!-- Progress Bar -->
                                                    <ProgressBar Grid.Row="2" Height="3" Minimum="0" Maximum="100" Value="{Binding WatchProgress}" Foreground="{DynamicResource AccentBlue}" Background="#25FFFFFF" BorderThickness="0"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Stream card grid -->
                <ListBox Grid.Row="4"
                         ItemsSource="{Binding Streams}"
                         SelectedItem="{Binding SelectedStream}"
                         ItemContainerStyle="{StaticResource StreamItemStyle}"
                         ItemTemplate="{StaticResource StreamCardTemplate}"
                         Background="Transparent" BorderThickness="0" Padding="10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding PlayCommand}"
                                      CommandParameter="{Binding SelectedStream}"/>
                    </ListBox.InputBindings>
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <!-- Show when browsing a normal category (not WhatsNew, not Downloads) -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="LiveTV"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="VOD"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="Series"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="CurrentlyWatching"/>
                                        <Condition Binding="{Binding SearchText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" Value="Visible"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <!-- Always show when viewing series episodes, regardless of ActiveSection -->
                                <DataTrigger Binding="{Binding IsViewingSeriesInfo}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <!-- My Library Grouped ScrollViewer (only visible when ActiveSection == CurrentlyWatching and SearchText is empty) -->
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ActiveSection}" Value="CurrentlyWatching"/>
                                        <Condition Binding="{Binding SearchText, Converter={StaticResource StringEmptyToVisibilityConverter}}" Value="Visible"/>
                                        <Condition Binding="{Binding IsViewingSeriesInfo}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    
                    <StackPanel>
                        <!-- 1. Continue Watching -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ContinueWatching.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconEye}" Stroke="{DynamicResource AccentBlue}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Continue Watching" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox Style="{StaticResource HorizontalListBoxStyle}"
                                     ItemsSource="{Binding ContinueWatching}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- 2. Liked Shows -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LikedShows.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconSeries}" Stroke="#FF4A5A" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Liked Shows" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox Style="{StaticResource HorizontalListBoxStyle}"
                                     ItemsSource="{Binding LikedShows}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- 3. Liked Live TV -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LikedLive.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconTv}" Stroke="#FF4A5A" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Liked Live TV" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox Style="{StaticResource HorizontalListBoxStyle}"
                                     ItemsSource="{Binding LikedLive}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- 4. Liked Movies -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LikedMovies.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10">
                                <Path Data="{StaticResource IconMovies}" Stroke="#FF4A5A" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Liked Movies" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ListBox Style="{StaticResource HorizontalListBoxStyle}"
                                     ItemsSource="{Binding LikedMovies}"
                                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                                     ItemTemplate="{StaticResource StreamCardTemplate}">
                                <ListBox.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding PlayCommand}"
                                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                </ListBox.InputBindings>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </StackPanel>

                        <!-- 5. Watch Later -->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WatchLater.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
