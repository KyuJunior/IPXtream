<Window x:Class="IPXtream.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="IPXtream"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F1A">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDeep"       Color="#0F0F1A"/>
        <SolidColorBrush x:Key="BgSidebar"    Color="#12122A"/>
        <SolidColorBrush x:Key="BgCard"       Color="#1A1A2E"/>
        <SolidColorBrush x:Key="BgHover"      Color="#22224A"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#4F8EF7"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E8E8F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#888899"/>
        <SolidColorBrush x:Key="InputBg"      Color="#12122A"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#2E2E50"/>
        <SolidColorBrush x:Key="DividerColor" Color="#1E1E3A"/>
        <SolidColorBrush x:Key="ErrorRed"     Color="#FF5370"/>

        <!-- ── Category list item ────────────────────────────────────────── -->
        <Style x:Key="CategoryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="4,2">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Stream card ───────────────────────────────────────────────── -->
        <Style x:Key="StreamItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Margin="{TemplateBinding Margin}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Search TextBox ────────────────────────────────────────────── -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource AccentBlue}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          Focusable="False"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Play button ───────────────────────────────────────────────── -->
        <Style x:Key="PlayBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#4F8EF7" Offset="0"/>
                                    <GradientStop Color="#7C5CBF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ── Window load animation ────────────────────────────────────────────── -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.35"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <!-- ── Root: sidebar | categories | streams ─────────────────────────────── -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ SIDEBAR ═══════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,24,20,20">
                    <Border Width="36" Height="36" CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4F8EF7" Offset="0"/>
                                <GradientStop Color="#7C5CBF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="📺" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="IPXtream" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Nav items — styles come from App.xaml, SectionToStyleConverter picks active -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">

                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="live"
                            Style="{Binding ActiveSection,
                                    Converter={StaticResource SectionToStyleConverter},
                                    ConverterParameter=LiveTV}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📡" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Live TV" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="vod"
                            Style="{Binding ActiveSection,
                                    Converter={StaticResource SectionToStyleConverter},
                                    ConverterParameter=VOD}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎬" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Movies" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectSectionCommand}" CommandParameter="series"
                            Style="{Binding ActiveSection,
                                    Converter={StaticResource SectionToStyleConverter},
                                    ConverterParameter=Series}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎞️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Series" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Height="1" Background="{StaticResource DividerColor}" Margin="16,16"/>

                    <Button Style="{StaticResource NavBtn}" Command="{Binding CacheAllBackgroundCommand}"
                            IsEnabled="{Binding IsCachingAll, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☁️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Cache Entire Library" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavBtn}" Command="{Binding RefreshCommand}"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↻" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Refresh Current View" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavBtn}" Command="{Binding LogoutCommand}"
                            Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" VerticalAlignment="Center"
                                       Foreground="{StaticResource ErrorRed}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User footer -->
                <Border Grid.Row="2" Background="{StaticResource BgCard}"
                        CornerRadius="12" Margin="12,0,12,16" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{Binding DisplayUsername}"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ServerDisplay}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════ CATEGORIES ═════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="{StaticResource BgDeep}"
                BorderBrush="{StaticResource DividerColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="16,16,16,12">
                    <StackPanel>
                        <TextBlock Text="CATEGORIES"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="Loading…"
                                   Foreground="{StaticResource AccentBlue}"
                                   FontSize="12" Margin="0,4,0,0"
                                   Visibility="{Binding IsLoadingCategories,
                                                Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- SelectedItem two-way binding triggers OnSelectedCategoryChanged in VM -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource CategoryItemStyle}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CategoryName}" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Error + Retry inside categories panel -->
                <Border Grid.Row="1" VerticalAlignment="Top"
                        Background="#441A0A" CornerRadius="8"
                        Padding="10,8" Margin="8,4"
                        Visibility="{Binding ErrorMessage,
                                     Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#FF7B6B" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <Button Command="{Binding SelectSectionCommand}"
                                CommandParameter="live"
                                Background="#4F8EF7" Foreground="White"
                                BorderThickness="0" Padding="8,4"
                                FontSize="11" FontWeight="Bold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            ↺ Retry
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════ STREAMS ════════════════════════════════════════════ -->
        <Grid Grid.Column="2" Background="{StaticResource BgDeep}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toolbar: search + category title -->
            <Border Grid.Row="0" Padding="16,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource SearchBox}" Height="38"
                             Foreground="White"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedCategory.CategoryName}"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Visibility="{Binding HasSelectedCategory,
                                            Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- Error banner -->
            <Border Grid.Row="0" VerticalAlignment="Bottom"
                    Background="#3DFF5370" CornerRadius="8"
                    Padding="12,6" Margin="16,0,16,4"
                    Visibility="{Binding ErrorMessage,
                                 Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorRed}" FontSize="12"/>
            </Border>

            <!-- Stream card grid -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Streams}"
                     SelectedItem="{Binding SelectedStream}"
                     ItemContainerStyle="{StaticResource StreamItemStyle}"
                     Background="Transparent" BorderThickness="0" Padding="10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Padding="12" CornerRadius="10">
                            <StackPanel>
                                <!-- Thumbnail -->
                                <Border Height="80" CornerRadius="8" Background="{StaticResource BgSidebar}"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Image Source="{Binding StreamIcon}" Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="LowQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <!-- Fallback icon -->
                                        <TextBlock Text="📺" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StreamIcon}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StreamIcon}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                                <!-- Name -->
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="12" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="136" Margin="0,0,0,8"/>
                                <!-- Play -->
                                <Button Style="{StaticResource PlayBtn}" Content="▶  PLAY"
                                        Command="{Binding DataContext.PlayCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding HasSelectedCategory,
                                     Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="👈" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Select a category to browse"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Loading overlay -->
            <Border Grid.Row="1" Background="#88000000"
                    Visibility="{Binding IsLoadingStreams,
                                 Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Loading streams…"
                           Foreground="{StaticResource AccentBlue}"
                           FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource DividerColor}" BorderThickness="0,1,0,0"
                    Padding="16,6">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMuted}" FontSize="12"/>
            </Border>
        </Grid>
    </Grid>
</Window>
